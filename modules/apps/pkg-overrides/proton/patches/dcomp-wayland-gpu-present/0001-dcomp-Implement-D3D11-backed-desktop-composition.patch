+    struct list      targets;              /* live IDCompositionTarget list */
+    struct list      visuals;              /* live IDCompositionVisual list */
+    struct list      surfaces;             /* live IDCompositionSurface list */
+    BOOL             pending_commit;
+
+    /* Some DComp clients commit once and then present new frames on the
+     * swap chain bound into the visual tree. A single Commit-time handoff
