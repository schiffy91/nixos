+static HRESULT WINAPI visual_SetContent(IDCompositionVisual2 *iface, IUnknown *content)
+{
+    struct dcomp_visual *v = impl_from_IDCompositionVisual2(iface);
+    TRACE("visual=%p content=%p\n", v, content);
+
+    if (v->device && v->device->cs_init) EnterCriticalSection(&v->device->cs);
+    if (v->content) IUnknown_Release(v->content);
+    v->content = content;
+    if (content)
+    {
+        IDXGISwapChain1   *sc1 = NULL;
+        IDCompositionSurface *sif = NULL;
+        IUnknown_AddRef(content);
+        /* Probe the visual content type. */
+        if (SUCCEEDED(IUnknown_QueryInterface(content, &IID_IDXGISwapChain1, (void **)&sc1)) && sc1)
+        {
+            DXGI_SWAP_CHAIN_DESC1 desc = {0};
+            ID3D11Texture2D *bb = NULL;
+            IDXGISwapChain1_GetDesc1(sc1, &desc);
+            HRESULT hr = IDXGISwapChain1_GetBuffer(sc1, 0, &IID_ID3D11Texture2D, (void **)&bb);
+            WARN("visual=%p content is IDXGISwapChain1=%p (%ux%u fmt=%u flags=%#x); GetBuffer hr=%#lx bb=%p\n",
+                 v, sc1, desc.Width, desc.Height, desc.Format, desc.Flags, hr, bb);
+            if (bb) ID3D11Texture2D_Release(bb);
+            IDXGISwapChain1_Release(sc1);
+        }
+        else if (SUCCEEDED(IUnknown_QueryInterface(content, &IID_IDCompositionSurface, (void **)&sif)) && sif)
+        {
+            struct dcomp_surface *s = impl_from_IDCompositionSurface(sif);
+            WARN("visual=%p content is IDCompositionSurface=%p (%ux%u fmt=%u draw_texture=%p)\n",
+                 v, s, s->width, s->height, s->format, s->draw_texture);
+            IDCompositionSurface_Release(sif);
+        }
+        else
+        {
+            WARN("visual=%p content=%p - unknown type (neither swap chain nor dcomp surface)\n", v, content);
+        }
+    }
+    v->dirty = TRUE;
+    if (v->device) v->device->pending_commit = TRUE;
+    if (v->device && v->device->cs_init) LeaveCriticalSection(&v->device->cs);
+    return S_OK;
+}
+
+static HRESULT WINAPI visual_AddVisual(IDCompositionVisual2 *iface, IDCompositionVisual *visual,
+                                       BOOL insert_above, IDCompositionVisual *ref_visual)
+{
+    struct dcomp_visual *p = impl_from_IDCompositionVisual2(iface);
+    struct dcomp_visual *c = NULL;
+    IDCompositionVisual2 *v2 = NULL;
+    if (!visual) return S_OK;
+    if (SUCCEEDED(IDCompositionVisual_QueryInterface(visual, &IID_IDCompositionVisual2, (void **)&v2)) && v2)
+    {
+        c = impl_from_IDCompositionVisual2(v2);
+        /* QI AddRef'd; don't release - parent retains via children list. */
+    }
+    if (!c) return S_OK;
+    if (p->device && p->device->cs_init) EnterCriticalSection(&p->device->cs);
+    if (c->parent)                       /* already in some parent's children - remove first */
+        list_remove(&c->child_entry);
+    c->parent = p;
+    list_add_tail(&p->children, &c->child_entry);
+    p->dirty = TRUE;
+    if (p->device) p->device->pending_commit = TRUE;
+    if (p->device && p->device->cs_init) LeaveCriticalSection(&p->device->cs);
+    TRACE("parent=%p added child=%p\n", p, c);
+    return S_OK;
+}
+
+static HRESULT WINAPI visual_RemoveVisual(IDCompositionVisual2 *iface, IDCompositionVisual *visual)
+{
+    struct dcomp_visual *p = impl_from_IDCompositionVisual2(iface);
+    IDCompositionVisual2 *v2 = NULL;
+    if (p->device && p->device->cs_init) EnterCriticalSection(&p->device->cs);
+    if (visual && SUCCEEDED(IDCompositionVisual_QueryInterface(visual, &IID_IDCompositionVisual2, (void **)&v2)) && v2)
+    {
+        struct dcomp_visual *c = impl_from_IDCompositionVisual2(v2);
+        if (c->parent == p) { list_remove(&c->child_entry); c->parent = NULL; }
+        IDCompositionVisual2_Release(v2);
+    }
+    p->dirty = TRUE;
+    if (p->device && p->device->cs_init) LeaveCriticalSection(&p->device->cs);
+    return S_OK;
+}
+
+static HRESULT WINAPI visual_RemoveAllVisuals(IDCompositionVisual2 *iface)
+{
+    struct dcomp_visual *p = impl_from_IDCompositionVisual2(iface);
+    struct dcomp_visual *c, *cn;
+    if (p->device && p->device->cs_init) EnterCriticalSection(&p->device->cs);
+    LIST_FOR_EACH_ENTRY_SAFE(c, cn, &p->children, struct dcomp_visual, child_entry)
+    {
+        list_remove(&c->child_entry); c->parent = NULL;
+    }
+    p->dirty = TRUE;
+    if (p->device && p->device->cs_init) LeaveCriticalSection(&p->device->cs);
+    return S_OK;
+}
