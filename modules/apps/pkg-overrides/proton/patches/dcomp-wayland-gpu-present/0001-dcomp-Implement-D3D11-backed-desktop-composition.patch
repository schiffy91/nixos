+static HRESULT WINAPI device_Commit(IDCompositionDesktopDevice *iface)
+{
+    struct dcomp_device *d = impl_from_IDCompositionDesktopDevice(iface);
+    struct dcomp_target *t;
+    int target_count = 0;
+    TRACE("device=%p\n", d);
+
+    if (d->cs_init) EnterCriticalSection(&d->cs);
+    LIST_FOR_EACH_ENTRY(t, &d->targets, struct dcomp_target, entry)
+    {
+        target_count++;
+        TRACE("  target=%p hwnd=%p root=%p\n", t, t->hwnd, t->root);
+    }
+    d->pending_commit = FALSE;
+    if (d->cs_init) LeaveCriticalSection(&d->cs);
+    if (!target_count) WARN("Commit with no targets registered\n");
+    return S_OK;
+}
