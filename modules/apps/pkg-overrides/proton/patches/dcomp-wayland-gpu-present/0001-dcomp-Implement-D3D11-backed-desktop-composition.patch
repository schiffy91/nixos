+/* Custom wndproc that explicitly routes driver messages to the wayland
+ * driver. wine's default window proc routes WM_WINE_*_DRIVER_MSG to
+ * user_driver->pWindowMessage, but built-in classes (Static, etc.) handle
+ * their own message dispatch and never reach DefWindowProc for these
+ * messages, so we need a dedicated wndproc here. */
+static LRESULT CALLBACK dcomp_ticker_wndproc(HWND hwnd, UINT msg,
+                                               WPARAM wp, LPARAM lp)
+{
+    /* Pass everything to DefWindowProcW - for messages in the WM_WINE_*
+     * driver range, that routes them to user_driver->pWindowMessage, which
+     * is wayland's WAYLAND_WindowMessage -> wayland_dcomp_handle_present. */
+    return DefWindowProcW(hwnd, msg, wp, lp);
+}
+
+static DWORD WINAPI dcomp_tick_thread(void *arg)
+{
+    struct dcomp_device *d = arg;
+    WNDCLASSW wc = {0};
+    static const WCHAR class_name[] = L"dcomp_ticker_class";
+
+    TRACE("ticker started device=%p\n", d);
+
+    /* Register a private window class with our wndproc so driver messages
+     * get routed through DefWindowProcW -> user_driver->pWindowMessage. */
+    wc.lpfnWndProc = dcomp_ticker_wndproc;
+    wc.lpszClassName = class_name;
+    RegisterClassW(&wc);     /* idempotent - class may already be registered */
+
+    /* Create a hidden HWND_MESSAGE window owned by THIS thread. SendMessage
+     * to a window whose owner thread is the caller dispatches the wndproc
+     * inline (no thread switch) - so WM_WAYLAND_DCOMP_PRESENT lands
+     * on wayland's WindowMessage handler on the ticker thread, not on
+     * app's UI thread. That keeps the per-frame GPU + wayland work off
+     * app's UI thread (which has to keep dispatching mouse/keyboard/IPC). */
+    d->ticker_hwnd = CreateWindowExW(0, class_name, L"dcomp-ticker",
+                                     0, 0, 0, 0, 0,
+                                     HWND_MESSAGE, NULL, NULL, NULL);
+    if (!d->ticker_hwnd)
+        WARN("failed to create ticker HWND, falling back to direct send\n");
+    else
+        TRACE("ticker HWND=%p (owner=this thread)\n", d->ticker_hwnd);
+
+    for (;;)
+    {
+        struct dcomp_target *snap[16];
+        int n = 0, i;
+        DWORD w = WaitForSingleObject(d->tick_stop, 16);
+        if (w == WAIT_OBJECT_0) break;                       /* stop signaled */
+
+        /* Snapshot the target list under the device cs, but do not hold the
+         * cs while walking visuals and sending driver messages. */
+        EnterCriticalSection(&d->cs);
+        {
+            struct dcomp_target *t;
+            LIST_FOR_EACH_ENTRY(t, &d->targets, struct dcomp_target, entry)
+            {
+                if (n >= (int)(sizeof(snap)/sizeof(snap[0]))) break;
+                IDCompositionTarget_AddRef(&t->IDCompositionTarget_iface);
+                snap[n++] = t;
+            }
+        }
+        LeaveCriticalSection(&d->cs);
+
+        for (i = 0; i < n; i++)
+        {
+            struct dcomp_target *t = snap[i];
+            if (t->root) dcomp_walk_visual_quiet(t, t->root);
+            IDCompositionTarget_Release(&t->IDCompositionTarget_iface);
+        }
+    }
+    TRACE("ticker exiting device=%p\n", d);
+    return 0;
+}
