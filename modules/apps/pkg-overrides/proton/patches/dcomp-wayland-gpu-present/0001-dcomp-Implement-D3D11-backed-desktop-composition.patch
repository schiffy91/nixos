+static HRESULT WINAPI surface_BeginDraw(IDCompositionSurface *iface, const RECT *rect,
+                                         REFIID iid, void **object, POINT *offset)
+{
+    struct dcomp_surface *s = impl_from_IDCompositionSurface(iface);
+    D3D11_TEXTURE2D_DESC desc = {0};
+    HRESULT hr;
+
+    TRACE("surface=%p rect=%p iid=%s\n", s, rect, debugstr_guid(iid));
+
+    if (!s->device || !s->device->d3d11_device)
+    {
+        FIXME("no D3D11 device available for BeginDraw\n");
+        *object = NULL;
+        return E_FAIL;
+    }
+    if (!IsEqualGUID(iid, &IID_ID3D11Texture2D))
