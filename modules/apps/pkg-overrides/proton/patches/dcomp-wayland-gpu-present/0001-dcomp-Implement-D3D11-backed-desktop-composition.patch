+static struct dcomp_visual *dcomp_visual_create(struct dcomp_device *device)
+{
+    struct dcomp_visual *v = calloc(1, sizeof(*v));
+    if (!v) return NULL;
+    v->IDCompositionVisual2_iface.lpVtbl = &dcomp_visual_vtbl;
+    v->ref = 1;
+    v->device = device;
+    v->transform.m11 = v->transform.m22 = 1.0f;
+    list_init(&v->children);
+    list_add_tail(&device->visuals, &v->entry);
+    TRACE("created visual %p\n", v);
+    return v;
+}
+
+static struct dcomp_surface *dcomp_surface_create(struct dcomp_device *device,
+                                                  UINT width, UINT height,
+                                                  DXGI_FORMAT format, DXGI_ALPHA_MODE alpha)
+{
+    struct dcomp_surface *s = calloc(1, sizeof(*s));
+    if (!s) return NULL;
+    s->IDCompositionSurface_iface.lpVtbl = &dcomp_surface_vtbl;
+    s->ref = 1;
+    s->device = device;
+    s->width = width;
+    s->height = height;
+    s->format = format;
+    s->alpha_mode = alpha;
+    list_add_tail(&device->surfaces, &s->entry);
+    TRACE("created surface %p (%ux%u fmt=%u alpha=%u)\n", s, width, height, format, alpha);
+    return s;
 }
 
