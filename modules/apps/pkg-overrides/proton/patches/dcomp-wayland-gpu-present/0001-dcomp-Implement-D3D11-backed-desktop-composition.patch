+/* ------------- bridge to winewayland.drv ------------- */
+#define WM_WAYLAND_DCOMP_PRESENT (0x80001003u)
+struct wayland_dcomp_present_request
+{
+    uint64_t  src_image;            /* VkImage (non-dispatchable, 64-bit) */
+    uint32_t  src_layout;           /* VkImageLayout */
+    uint32_t  vk_format;            /* VkFormat */
+    uint32_t  width, height;
+    uint64_t  vk_instance;          /* dispatchable handles, stored uint64 for PE/Unix layout */
+    uint64_t  vk_physical_device;
+    uint64_t  vk_device;
+    uint64_t  vk_queue;
+    uint32_t  queue_family;
+    uint32_t  _pad;
+    /* HWND of the DComp target - used by the unix-side handler to look up
+     * the wayland_surface and (lazily) build the compositing subsurface.
+     * Carried in the request rather than the WM message's hwnd because we
+     * SendMessage to a hidden window owned by the dcomp ticker thread (so
+     * the wndproc dispatch happens inline on the ticker, not on app's UI
+     * thread which would otherwise block on our vkSubmit + vkWaitForFences
+     * and stall input/IPC dispatch). */
+    uint64_t target_hwnd;
+};
