+++ b/dlls/winewayland.drv/window.c
@@ -741,6 +741,13 @@ LRESULT WAYLAND_WindowMessage(HWND hwnd, UINT msg, WPARAM wp, LPARAM lp)
     case WM_WAYLAND_SET_FOREGROUND:
         NtUserSetForegroundWindow(hwnd);
         return 0;
+    case WM_WAYLAND_DCOMP_PRESENT:
+    {
+        struct wayland_dcomp_present_request *req = (struct wayland_dcomp_present_request *)lp;
+        if (!req) { ERR("WM_WAYLAND_DCOMP_PRESENT NULL request\n"); return 0; }
+        wayland_dcomp_handle_present(hwnd, req);
+        return 0;
+    }
     default:
         FIXME("got window msg %x hwnd %p wp %lx lp %lx\n", msg, hwnd, (long)wp, lp);
         return 0;
