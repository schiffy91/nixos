index 182b2d9..2da1a6e 100644
--- a/dlls/winewayland.drv/window.c
+++ b/dlls/winewayland.drv/window.c
@@ -33,6 +33,7 @@
 #include "waylanddrv.h"
 
 #include "wine/debug.h"
+#include "wine/server.h"
 
 WINE_DEFAULT_DEBUG_CHANNEL(waylanddrv);
 
@@ -830,13 +831,52 @@ void ensure_window_surface_contents(HWND hwnd)
  *          WAYLAND_UpdateLayeredWindow
  *
  * Called by win32u after UpdateLayeredWindow[Indirect] has written new
- * pixel data into the window surface.  Commit the pending shm buffer so
- * the compositor shows the frame.  Without this the wl_surface stays
- * uncommitted and the window is a blank / transparent rectangle.
+ * pixel data into the window surface.  Two paths:
+ *
+ *  1. Normal path (wl_shm): the window surface bitmap was populated from
+ *     the hdcSrc (either by win32u GDI copy or DXVK staging readback).
+ *     Calling ensure_window_surface_contents() commits the pending shm
+ *     buffer to the wl_surface.
+ *
+ *  2. GPU-child dmabuf path: the CEF GPU child rendered into an EGL surface
+ *     and called wayland_share_dmabuf_for_hwnd() before this notification
+ *     reached the browser process.  We retrieve the fd from the wineserver
+ *     and attach it as a zero-copy wl_buffer via zwp_linux_dmabuf_v1.
+ *
+ * Without this hook the wl_surface stays uncommitted and the window is a
+ * blank / transparent rectangle.
  */
 void WAYLAND_UpdateLayeredWindow(HWND hwnd, UINT flags)
 {
+    struct wayland_win_data *data;
+    struct wayland_surface *surface;
+    int dmabuf_fd;
+    int dmabuf_w, dmabuf_h;
+    uint32_t dmabuf_fmt, dmabuf_stride;
+    uint64_t dmabuf_mod;
+
     TRACE("hwnd=%p flags=%#x\n", hwnd, flags);
+
+    /* Try the GPU-child dmabuf path first (zero-copy). */
+    if (wayland_get_dmabuf_for_hwnd(hwnd, &dmabuf_fd, &dmabuf_w, &dmabuf_h,
+                                     &dmabuf_fmt, &dmabuf_stride, &dmabuf_mod))
+    {
+        if ((data = wayland_win_data_get(hwnd)))
+        {
+            surface = data->wayland_surface;
+            if (surface)
+                wayland_surface_attach_dmabuf(surface, dmabuf_fd,
+                                              dmabuf_w, dmabuf_h,
+                                              dmabuf_fmt, dmabuf_stride,
+                                              dmabuf_mod);
+            wayland_win_data_release(data);
+        }
+        close(dmabuf_fd);
+        return;
+    }
+
+    /* Fall back to the wl_shm path (works for software rendering and for
+     * GPU rendering when DXVK's staging readback succeeded). */
     ensure_window_surface_contents(hwnd);
     wl_display_flush(process_wayland.wl_display);
 }
