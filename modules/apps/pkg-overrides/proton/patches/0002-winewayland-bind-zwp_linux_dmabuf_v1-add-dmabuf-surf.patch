diff --git a/dlls/winewayland.drv/wayland_dmabuf.c b/dlls/winewayland.drv/wayland_dmabuf.c
new file mode 100644
index 0000000..c9ea7ea
--- /dev/null
+++ b/dlls/winewayland.drv/wayland_dmabuf.c
@@ -0,0 +1,210 @@
+/*
+ * Wayland dmabuf cross-process surface sharing
+ *
+ * Copyright 2025 scwhine for FRACTAL-NORTH
+ *
+ * Implements the two-process dmabuf IPC path needed for CEF-based launchers
+ * (Battle.net, Ubisoft Connect, EA App) running under winewayland.drv:
+ *
+ *   GPU child process:
+ *     1. Renders into an EGL surface (wl_egl_window-backed WGL context).
+ *     2. Exports the framebuffer as a Linux dmabuf fd via
+ *        EGL_MESA_image_dma_buf_export.
+ *     3. Calls wayland_share_dmabuf_for_hwnd() to hand the fd + metadata to
+ *        the wineserver, keyed by the layered HWND.
+ *
+ *   Browser process (layered HWND owner):
+ *     4. WAYLAND_UpdateLayeredWindow() calls wayland_get_dmabuf_for_hwnd() to
+ *        retrieve the pending fd from the wineserver.
+ *     5. Creates a wl_buffer via zwp_linux_dmabuf_v1 and attaches it to the
+ *        wl_surface, then commits.
+ *
+ * The wineserver acts as the fd broker; see server/wayland_dmabuf.c for the
+ * REQ_share_dmabuf_fd / REQ_get_dmabuf_fd handlers.
+ */
+
+#if 0
+#pragma makedep unix
+#endif
+
+#include "config.h"
+
+#include <errno.h>
+#include <fcntl.h>
+#include <stdlib.h>
+#include <string.h>
+#include <unistd.h>
+
+#include "ntstatus.h"
+#define WIN32_NO_STATUS
+
+#include "waylanddrv.h"
+#include "wine/debug.h"
+#include "wine/server.h"
+
+WINE_DEFAULT_DEBUG_CHANNEL(waylanddrv);
+
+/* -----------------------------------------------------------------------
+ * wl_buffer creation from a dmabuf fd
+ * ----------------------------------------------------------------------- */
+
+struct dmabuf_buffer_data
+{
+    struct wl_buffer *wl_buffer;
+    BOOL created;
+};
+
+static void dmabuf_buffer_created(void *data,
+                                  struct zwp_linux_buffer_params_v1 *params,
+                                  struct wl_buffer *buffer)
+{
+    struct dmabuf_buffer_data *d = data;
+    d->wl_buffer = buffer;
+    d->created = TRUE;
+}
+
+static void dmabuf_buffer_failed(void *data,
+                                 struct zwp_linux_buffer_params_v1 *params)
+{
+    struct dmabuf_buffer_data *d = data;
+    d->wl_buffer = NULL;
+    d->created = TRUE;
+}
+
+static const struct zwp_linux_buffer_params_v1_listener params_listener =
+{
+    dmabuf_buffer_created,
+    dmabuf_buffer_failed,
+};
+
+static void buffer_release(void *data, struct wl_buffer *buffer)
+{
+    wl_buffer_destroy(buffer);
+}
+
+static const struct wl_buffer_listener dmabuf_buffer_listener = { buffer_release };
+
+/**
+ * wayland_surface_attach_dmabuf - import a dmabuf fd and commit it to a
+ * wayland_surface.
+ *
+ * @fd: caller retains ownership; we dup it internally.
+ * Returns TRUE if the wl_buffer was successfully created and committed.
+ */
+BOOL wayland_surface_attach_dmabuf(struct wayland_surface *surface,
+                                    int fd, int width, int height,
+                                    uint32_t format, uint32_t stride,
+                                    uint64_t modifier)
+{
+    struct zwp_linux_buffer_params_v1 *params;
+    struct dmabuf_buffer_data data = {0};
+    struct wl_event_queue *queue;
+    int dup_fd;
+
+    if (!process_wayland.zwp_linux_dmabuf_v1)
+    {
+        WARN("zwp_linux_dmabuf_v1 not available\n");
+        return FALSE;
+    }
+
+    dup_fd = fcntl(fd, F_DUPFD_CLOEXEC, 0);
+    if (dup_fd < 0)
+    {
+        ERR("dup failed: %s\n", strerror(errno));
+        return FALSE;
+    }
+
+    queue = wl_display_create_queue(process_wayland.wl_display);
+    params = zwp_linux_dmabuf_v1_create_params(process_wayland.zwp_linux_dmabuf_v1);
+    wl_proxy_set_queue((struct wl_proxy *)params, queue);
+    zwp_linux_buffer_params_v1_add_listener(params, &params_listener, &data);
+
+    zwp_linux_buffer_params_v1_add(params, dup_fd, 0 /* plane_idx */,
+                                   0 /* offset */, stride,
+                                   (uint32_t)(modifier >> 32),
+                                   (uint32_t)(modifier & 0xffffffffu));
+    close(dup_fd);
+
+    zwp_linux_buffer_params_v1_create(params, width, height, format, 0 /* flags */);
+
+    /* Synchronously wait for the buffer_created / buffer_failed event. */
+    while (!data.created)
+        wl_display_dispatch_queue(process_wayland.wl_display, queue);
+
+    zwp_linux_buffer_params_v1_destroy(params);
+    wl_event_queue_destroy(queue);
+
+    if (!data.wl_buffer)
+    {
+        ERR("zwp_linux_buffer_params_v1_create failed\n");
+        return FALSE;
+    }
+
+    wl_buffer_add_listener(data.wl_buffer, &dmabuf_buffer_listener, NULL);
+
+    if (!wayland_surface_reconfigure(surface))
+    {
+        wl_buffer_destroy(data.wl_buffer);
+        TRACE("surface not yet configured, dropping dmabuf frame\n");
+        return FALSE;
+    }
+
+    wl_surface_attach(surface->wl_surface, data.wl_buffer, 0, 0);
+    wl_surface_damage_buffer(surface->wl_surface, 0, 0, width, height);
+    wl_surface_commit(surface->wl_surface);
+    wl_display_flush(process_wayland.wl_display);
+
+    TRACE("hwnd=%p %dx%d fmt=%#x stride=%u mod=%#"PRIx64"\n",
+          surface->hwnd, width, height, format, stride, modifier);
+    return TRUE;
+}
+
+/* -----------------------------------------------------------------------
+ * Wineserver-based cross-process dmabuf fd sharing
+ *
+ * The GPU child calls wayland_share_dmabuf_for_hwnd() to push the fd to the
+ * wineserver.  The browser calls wayland_get_dmabuf_for_hwnd() to retrieve it.
+ * -----------------------------------------------------------------------*/
+
+void wayland_share_dmabuf_for_hwnd(HWND hwnd, int fd, int width, int height,
+                                    uint32_t format, uint32_t stride,
+                                    uint64_t modifier)
+{
+    wine_server_send_fd(fd);
+    SERVER_START_REQ(share_dmabuf_fd)
+    {
+        req->hwnd         = wine_server_user_handle(hwnd);
+        req->fd           = fd;
+        req->width        = width;
+        req->height       = height;
+        req->format       = format;
+        req->stride       = stride;
+        req->modifier_lo  = (unsigned int)(modifier & 0xffffffffu);
+        req->modifier_hi  = (unsigned int)(modifier >> 32);
+        wine_server_call(req);
+    }
+    SERVER_END_REQ;
+}
+
+BOOL wayland_get_dmabuf_for_hwnd(HWND hwnd, int *fd_out, int *w_out, int *h_out,
+                                  uint32_t *fmt_out, uint32_t *stride_out,
+                                  uint64_t *mod_out)
+{
+    BOOL found = FALSE;
+    SERVER_START_REQ(get_dmabuf_fd)
+    {
+        req->hwnd = wine_server_user_handle(hwnd);
+        if (!wine_server_call(req))
+        {
+            *fd_out     = wine_server_recv_fd(reply->fd);
+            *w_out      = reply->width;
+            *h_out      = reply->height;
+            *fmt_out    = reply->format;
+            *stride_out = reply->stride;
+            *mod_out    = ((uint64_t)reply->modifier_hi << 32) | reply->modifier_lo;
+            found = TRUE;
+        }
+    }
+    SERVER_END_REQ;
+    return found;
+}
diff --git a/dlls/winewayland.drv/wayland_systray.c b/dlls/winewayland.drv/wayland_systray.c
new file mode 100644
index 0000000..0949fe7
--- /dev/null
+++ b/dlls/winewayland.drv/wayland_systray.c
@@ -0,0 +1,553 @@
+/*
+ * Wayland systray via freedesktop StatusNotifierItem (D-Bus)
+ *
+ * Copyright 2025 scwhine for FRACTAL-NORTH
+ *
+ * Implements pSystrayDockInit / pSystrayDockInsert / pSystrayDockClear /
+ * pSystrayDockRemove using the org.kde.StatusNotifierItem specification.
+ * Works on KDE Plasma 6, GNOME + AppIndicator extension, and wlroots panels
+ * (Waybar).  No XWayland or xembedsniproxy required.
+ *
+ * Architecture (H5 from the design doc):
+ *   All NtUserSystemTrayCall dispatches happen in explorer.exe.  One libdbus
+ *   connection lives here; each call to pSystrayDockInsert registers a new
+ *   StatusNotifierItem service for the icon.  SNI method calls (Activate,
+ *   SecondaryActivate, ContextMenu, Scroll) are translated back to the Win32
+ *   callback message the app registered with Shell_NotifyIcon.
+ *
+ * The `void *icon` parameter is `struct icon *` from programs/explorer/systray.c
+ * (see H3 and the explorer source).  We read image, owner, callback_message,
+ * id, and tiptext from it.
+ */
+
+#if 0
+#pragma makedep unix
+#endif
+
+#include "config.h"
+
+#ifdef HAVE_DBUS_DBUS_H
+
+#include <dbus/dbus.h>
+
+#include <pthread.h>
+#include <stdint.h>
+#include <stdlib.h>
+#include <string.h>
+#include <unistd.h>
+
+#include "ntstatus.h"
+#define WIN32_NO_STATUS
+
+#include "waylanddrv.h"
+#include "wine/debug.h"
+
+WINE_DEFAULT_DEBUG_CHANNEL(systray);
+
+/* -----------------------------------------------------------------------
+ * Icon metadata — mirrors the fields we need from explorer's struct icon.
+ * We define only what we use; the caller passes a void* which we cast to
+ * this layout.  It must stay in sync with programs/explorer/systray.c.
+ * ----------------------------------------------------------------------- */
+struct explorer_icon
+{
+    /* struct list entry (two pointers) */
+    void       *list_fwd;
+    void       *list_bwd;
+    HICON       image;
+    HWND        owner;
+    HWND        window;
+    BOOL        layered;
+    HWND        tooltip;
+    UINT        state;
+    UINT        id;
+    UINT        callback_message;
+    int         display;
+    WCHAR       tiptext[128];
+    /* remaining fields not needed here */
+};
+
+/* -----------------------------------------------------------------------
+ * Per-icon D-Bus service state
+ * ----------------------------------------------------------------------- */
+struct sni_item
+{
+    struct list          entry;
+    int                  serial;       /* unique suffix for the service name */
+    DBusConnection      *conn;
+    HWND                 owner;
+    UINT                 id;
+    UINT                 callback_message;
+    HWND                 callback_hwnd; /* == window in explorer's struct icon */
+
+    /* Icon pixmap data (ARGB32 big-endian, for the SNI (iiay) variant). */
+    int                  icon_w, icon_h;
+    unsigned char       *icon_argb;    /* w*h*4 bytes, may be NULL */
+
+    WCHAR                tiptext[128];
+    pthread_t            dispatch_thread;
+    BOOL                 running;
+};
+
+static struct list sni_list = LIST_INIT(sni_list);
+static int sni_serial;
+static pthread_mutex_t sni_mutex = PTHREAD_MUTEX_INITIALIZER;
+
+/* -----------------------------------------------------------------------
+ * Helpers
+ * ----------------------------------------------------------------------- */
+
+static void utf8_from_wchar(const WCHAR *src, char *dst, size_t dst_size)
+{
+    ULONG bytes;
+    if (!RtlUnicodeToUTF8N(NULL, 0, &bytes, src, (lstrlenW(src) + 1) * sizeof(WCHAR)))
+        RtlUnicodeToUTF8N(dst, dst_size, &bytes, src, (lstrlenW(src) + 1) * sizeof(WCHAR));
+    else
+        dst[0] = '\0';
+}
+
+/* Extract ARGB32 pixels from an HICON via GDI. */
+static unsigned char *icon_to_argb(HICON hicon, int *w_out, int *h_out)
+{
+    ICONINFOEXW info = { sizeof(info) };
+    BITMAPINFOHEADER bih = { sizeof(bih) };
+    unsigned char *argb = NULL;
+    HDC hdc;
+    int w, h;
+
+    if (!NtUserGetIconInfo((HICON)hicon, (ICONINFO *)&info, NULL, NULL, NULL, 0))
+        return NULL;
+
+    /* Use the colour bitmap dimensions. */
+    bih.biSize = sizeof(bih);
+    hdc = NtUserGetDC(NULL);
+    if (!NtGdiGetDIBitsInternal(hdc, info.hbmColor, 0, 0, NULL,
+                                (BITMAPINFO *)&bih, DIB_RGB_COLORS, 0, 0))
+        goto done;
+
+    w = bih.biWidth;
+    h = abs(bih.biHeight);
+    if (w <= 0 || h <= 0) goto done;
+
+    bih.biBitCount    = 32;
+    bih.biCompression = BI_RGB;
+    bih.biHeight      = -h; /* top-down */
+    bih.biSizeImage   = w * h * 4;
+
+    if (!(argb = malloc(w * h * 4))) goto done;
+
+    if (!NtGdiGetDIBitsInternal(hdc, info.hbmColor, 0, h, argb,
+                                (BITMAPINFO *)&bih, DIB_RGB_COLORS, w * h * 4, 0))
+    {
+        free(argb);
+        argb = NULL;
+        goto done;
+    }
+
+    /* GDI returns BGRA; SNI expects ARGB big-endian (network byte order). */
+    for (int i = 0; i < w * h; i++)
+    {
+        unsigned char b = argb[i * 4 + 0];
+        unsigned char g = argb[i * 4 + 1];
+        unsigned char r = argb[i * 4 + 2];
+        unsigned char a = argb[i * 4 + 3];
+        /* Store as big-endian ARGB in the array that D-Bus will serialise. */
+        argb[i * 4 + 0] = a;
+        argb[i * 4 + 1] = r;
+        argb[i * 4 + 2] = g;
+        argb[i * 4 + 3] = b;
+    }
+
+    *w_out = w;
+    *h_out = h;
+
+done:
+    NtUserReleaseDC(NULL, hdc);
+    if (info.hbmColor) NtGdiDeleteObjectApp(info.hbmColor);
+    if (info.hbmMask)  NtGdiDeleteObjectApp(info.hbmMask);
+    return argb;
+}
+
+/* -----------------------------------------------------------------------
+ * D-Bus StatusNotifierItem introspection XML
+ * ----------------------------------------------------------------------- */
+static const char sni_introspect[] =
+    "<!DOCTYPE node PUBLIC \"-//freedesktop//DTD D-BUS Object Introspection 1.0//EN\"\n"
+    "\"http://www.freedesktop.org/standards/dbus/1.0/introspect.dtd\">\n"
+    "<node>\n"
+    "  <interface name=\"org.kde.StatusNotifierItem\">\n"
+    "    <property name=\"Id\"          type=\"s\" access=\"read\"/>\n"
+    "    <property name=\"Category\"    type=\"s\" access=\"read\"/>\n"
+    "    <property name=\"Status\"      type=\"s\" access=\"read\"/>\n"
+    "    <property name=\"Title\"       type=\"s\" access=\"read\"/>\n"
+    "    <property name=\"IconPixmap\"  type=\"a(iiay)\" access=\"read\"/>\n"
+    "    <property name=\"ToolTip\"     type=\"(sa(iiay)ss)\" access=\"read\"/>\n"
+    "    <method name=\"Activate\"><arg name=\"x\" type=\"i\"/><arg name=\"y\" type=\"i\"/></method>\n"
+    "    <method name=\"SecondaryActivate\"><arg name=\"x\" type=\"i\"/><arg name=\"y\" type=\"i\"/></method>\n"
+    "    <method name=\"ContextMenu\"><arg name=\"x\" type=\"i\"/><arg name=\"y\" type=\"i\"/></method>\n"
+    "    <method name=\"Scroll\"><arg name=\"delta\" type=\"i\"/><arg name=\"orientation\" type=\"s\"/></method>\n"
+    "    <signal name=\"NewIcon\"/>\n"
+    "    <signal name=\"NewTitle\"/>\n"
+    "    <signal name=\"NewStatus\"><arg name=\"status\" type=\"s\"/></signal>\n"
+    "  </interface>\n"
+    "  <interface name=\"org.freedesktop.DBus.Introspectable\">\n"
+    "    <method name=\"Introspect\"><arg name=\"xml\" type=\"s\" direction=\"out\"/></method>\n"
+    "  </interface>\n"
+    "  <interface name=\"org.freedesktop.DBus.Properties\">\n"
+    "    <method name=\"Get\">\n"
+    "      <arg name=\"interface\" type=\"s\" direction=\"in\"/>\n"
+    "      <arg name=\"name\"      type=\"s\" direction=\"in\"/>\n"
+    "      <arg name=\"value\"     type=\"v\" direction=\"out\"/>\n"
+    "    </method>\n"
+    "  </interface>\n"
+    "</node>\n";
+
+/* -----------------------------------------------------------------------
+ * Append IconPixmap variant: a(iiay)
+ * ----------------------------------------------------------------------- */
+static void append_icon_pixmap(DBusMessageIter *iter, struct sni_item *item)
+{
+    DBusMessageIter arr, st, bytes;
+    dbus_int32_t w = item->icon_w, h = item->icon_h;
+
+    dbus_message_iter_open_container(iter, DBUS_TYPE_ARRAY, "(iiay)", &arr);
+    if (item->icon_argb && w > 0 && h > 0)
+    {
+        dbus_message_iter_open_container(&arr, DBUS_TYPE_STRUCT, NULL, &st);
+        dbus_message_iter_append_basic(&st, DBUS_TYPE_INT32, &w);
+        dbus_message_iter_append_basic(&st, DBUS_TYPE_INT32, &h);
+        dbus_message_iter_open_container(&st, DBUS_TYPE_ARRAY, "y", &bytes);
+        dbus_message_iter_append_fixed_array(&bytes, DBUS_TYPE_BYTE,
+                                             &item->icon_argb,
+                                             (int)(w * h * 4));
+        dbus_message_iter_close_container(&st, &bytes);
+        dbus_message_iter_close_container(&arr, &st);
+    }
+    dbus_message_iter_close_container(iter, &arr);
+}
+
+/* -----------------------------------------------------------------------
+ * D-Bus message handler for the SNI object
+ * ----------------------------------------------------------------------- */
+static DBusHandlerResult sni_message_handler(DBusConnection *conn,
+                                              DBusMessage *msg,
+                                              void *user_data)
+{
+    struct sni_item *item = user_data;
+    const char *iface  = dbus_message_get_interface(msg);
+    const char *member = dbus_message_get_member(msg);
+    DBusMessage *reply  = NULL;
+
+    /* org.freedesktop.DBus.Introspectable.Introspect */
+    if (dbus_message_is_method_call(msg, DBUS_INTERFACE_INTROSPECTABLE, "Introspect"))
+    {
+        reply = dbus_message_new_method_return(msg);
+        dbus_message_append_args(reply, DBUS_TYPE_STRING, &sni_introspect,
+                                 DBUS_TYPE_INVALID);
+        goto send;
+    }
+
+    /* org.freedesktop.DBus.Properties.Get */
+    if (dbus_message_is_method_call(msg, DBUS_INTERFACE_PROPERTIES, "Get"))
+    {
+        const char *prop_name = NULL;
+        DBusMessageIter args, var;
+
+        dbus_message_get_args(msg, NULL, DBUS_TYPE_STRING, &iface,
+                              DBUS_TYPE_STRING, &prop_name, DBUS_TYPE_INVALID);
+
+        reply = dbus_message_new_method_return(msg);
+        dbus_message_iter_init_append(reply, &args);
+
+        if (!prop_name) goto send;
+
+        if (!strcmp(prop_name, "Id") || !strcmp(prop_name, "Category") ||
+            !strcmp(prop_name, "Status") || !strcmp(prop_name, "Title"))
+        {
+            const char *str;
+            char id_buf[64];
+            if (!strcmp(prop_name, "Id"))
+            {
+                snprintf(id_buf, sizeof(id_buf), "wine-tray-%d", item->serial);
+                str = id_buf;
+            }
+            else if (!strcmp(prop_name, "Category")) str = "ApplicationStatus";
+            else if (!strcmp(prop_name, "Status"))   str = "Active";
+            else /* Title */
+            {
+                char tip[256];
+                utf8_from_wchar(item->tiptext, tip, sizeof(tip));
+                str = tip;
+            }
+            dbus_message_iter_open_container(&args, DBUS_TYPE_VARIANT, "s", &var);
+            dbus_message_iter_append_basic(&var, DBUS_TYPE_STRING, &str);
+            dbus_message_iter_close_container(&args, &var);
+        }
+        else if (!strcmp(prop_name, "IconPixmap"))
+        {
+            dbus_message_iter_open_container(&args, DBUS_TYPE_VARIANT, "a(iiay)", &var);
+            append_icon_pixmap(&var, item);
+            dbus_message_iter_close_container(&args, &var);
+        }
+        else if (!strcmp(prop_name, "ToolTip"))
+        {
+            /* (sa(iiay)ss) */
+            DBusMessageIter st;
+            char tip[256];
+            const char *empty = "";
+            utf8_from_wchar(item->tiptext, tip, sizeof(tip));
+            dbus_message_iter_open_container(&args, DBUS_TYPE_VARIANT, "(sa(iiay)ss)", &var);
+            dbus_message_iter_open_container(&var, DBUS_TYPE_STRUCT, NULL, &st);
+            dbus_message_iter_append_basic(&st, DBUS_TYPE_STRING, &empty); /* icon name */
+            append_icon_pixmap(&st, item);
+            dbus_message_iter_append_basic(&st, DBUS_TYPE_STRING, &tip);   /* title */
+            dbus_message_iter_append_basic(&st, DBUS_TYPE_STRING, &empty); /* body */
+            dbus_message_iter_close_container(&var, &st);
+            dbus_message_iter_close_container(&args, &var);
+        }
+        goto send;
+    }
+
+    /* org.kde.StatusNotifierItem method calls → forward as Win32 messages */
+    if (!strcmp(iface, "org.kde.StatusNotifierItem"))
+    {
+        UINT win_msg = 0;
+        dbus_int32_t x = 0, y = 0;
+
+        if (!strcmp(member, "Activate"))          win_msg = WM_LBUTTONUP;
+        else if (!strcmp(member, "SecondaryActivate")) win_msg = WM_MBUTTONUP;
+        else if (!strcmp(member, "ContextMenu"))  win_msg = WM_RBUTTONUP;
+        else if (!strcmp(member, "Scroll"))
+        {
+            dbus_int32_t delta = 0;
+            dbus_message_get_args(msg, NULL,
+                                  DBUS_TYPE_INT32, &delta,
+                                  DBUS_TYPE_INVALID);
+            NtUserMessageCall(item->callback_hwnd, item->callback_message,
+                              item->id,
+                              MAKELPARAM(0, (short)(delta > 0 ? WHEEL_DELTA : -WHEEL_DELTA)),
+                              NULL, NtUserSendNotifyMessage, FALSE);
+            reply = dbus_message_new_method_return(msg);
+            goto send;
+        }
+
+        if (win_msg)
+        {
+            dbus_message_get_args(msg, NULL,
+                                  DBUS_TYPE_INT32, &x,
+                                  DBUS_TYPE_INT32, &y,
+                                  DBUS_TYPE_INVALID);
+            NtUserMessageCall(item->callback_hwnd, item->callback_message,
+                              item->id, MAKELPARAM(x, y) /* best-effort position */,
+                              NULL, NtUserSendNotifyMessage, FALSE);
+            NtUserMessageCall(item->callback_hwnd, item->callback_message,
+                              item->id, win_msg,
+                              NULL, NtUserSendNotifyMessage, FALSE);
+        }
+
+        reply = dbus_message_new_method_return(msg);
+        goto send;
+    }
+
+    return DBUS_HANDLER_RESULT_NOT_YET_HANDLED;
+
+send:
+    if (reply)
+    {
+        dbus_connection_send(conn, reply, NULL);
+        dbus_message_unref(reply);
+    }
+    return DBUS_HANDLER_RESULT_HANDLED;
+}
+
+static const DBusObjectPathVTable sni_vtable = {
+    NULL,
+    sni_message_handler,
+};
+
+/* -----------------------------------------------------------------------
+ * Per-icon D-Bus dispatch thread
+ * ----------------------------------------------------------------------- */
+static void *sni_dispatch_thread(void *arg)
+{
+    struct sni_item *item = arg;
+    while (item->running && dbus_connection_read_write_dispatch(item->conn, 200))
+        ;
+    return NULL;
+}
+
+/* -----------------------------------------------------------------------
+ * Public hooks (called from explorer.exe via NtUserSystemTrayCall)
+ * ----------------------------------------------------------------------- */
+
+void WAYLAND_SystrayDockInit(HWND hwnd)
+{
+    TRACE("hwnd=%p (no-op on Wayland; SNI registered per-icon)\n", hwnd);
+}
+
+BOOL WAYLAND_SystrayDockInsert(HWND hwnd, UINT cx, UINT cy, void *icon_data)
+{
+    struct explorer_icon *icon = icon_data;
+    struct sni_item *item;
+    DBusError err;
+    char service[128], obj_path[] = "/StatusNotifierItem";
+    char rule[256];
+    int ret;
+
+    if (!icon) return FALSE;
+
+    dbus_error_init(&err);
+
+    item = calloc(1, sizeof(*item));
+    if (!item) return FALSE;
+
+    pthread_mutex_lock(&sni_mutex);
+    item->serial           = ++sni_serial;
+    pthread_mutex_unlock(&sni_mutex);
+
+    item->owner            = icon->owner;
+    item->id               = icon->id;
+    item->callback_message = icon->callback_message;
+    item->callback_hwnd    = icon->window;
+    memcpy(item->tiptext, icon->tiptext, sizeof(item->tiptext));
+
+    /* Extract icon pixmap. */
+    if (icon->image)
+        item->icon_argb = icon_to_argb(icon->image, &item->icon_w, &item->icon_h);
+
+    /* Unique per-process-per-icon service name. */
+    snprintf(service, sizeof(service),
+             "org.kde.StatusNotifierItem-%d-%d",
+             (int)getpid(), item->serial);
+
+    item->conn = dbus_bus_get_private(DBUS_BUS_SESSION, &err);
+    if (!item->conn || dbus_error_is_set(&err))
+    {
+        ERR("D-Bus connection failed: %s\n", err.message);
+        dbus_error_free(&err);
+        free(item->icon_argb);
+        free(item);
+        return FALSE;
+    }
+
+    ret = dbus_bus_request_name(item->conn, service,
+                                DBUS_NAME_FLAG_REPLACE_EXISTING, &err);
+    if (ret != DBUS_REQUEST_NAME_REPLY_PRIMARY_OWNER || dbus_error_is_set(&err))
+    {
+        WARN("Could not acquire %s: %s\n", service, err.message);
+        dbus_error_free(&err);
+        dbus_connection_close(item->conn);
+        dbus_connection_unref(item->conn);
+        free(item->icon_argb);
+        free(item);
+        return FALSE;
+    }
+
+    if (!dbus_connection_register_object_path(item->conn, obj_path, &sni_vtable, item))
+    {
+        ERR("register_object_path failed\n");
+        dbus_connection_close(item->conn);
+        dbus_connection_unref(item->conn);
+        free(item->icon_argb);
+        free(item);
+        return FALSE;
+    }
+
+    /* Register with org.kde.StatusNotifierWatcher. */
+    {
+        DBusMessage *reg = dbus_message_new_method_call(
+            "org.kde.StatusNotifierWatcher",
+            "/StatusNotifierWatcher",
+            "org.kde.StatusNotifierWatcher",
+            "RegisterStatusNotifierItem");
+        if (reg)
+        {
+            const char *svc = service;
+            dbus_message_append_args(reg, DBUS_TYPE_STRING, &svc, DBUS_TYPE_INVALID);
+            dbus_connection_send(item->conn, reg, NULL);
+            dbus_message_unref(reg);
+            dbus_connection_flush(item->conn);
+        }
+    }
+
+    /* Match signals we might need in the future. */
+    snprintf(rule, sizeof(rule),
+             "type='signal',sender='org.kde.StatusNotifierWatcher'");
+    dbus_bus_add_match(item->conn, rule, NULL);
+
+    item->running = TRUE;
+    pthread_create(&item->dispatch_thread, NULL, sni_dispatch_thread, item);
+
+    pthread_mutex_lock(&sni_mutex);
+    list_add_tail(&sni_list, &item->entry);
+    pthread_mutex_unlock(&sni_mutex);
+
+    TRACE("registered SNI %s for hwnd=%p owner=%p id=%u\n",
+          service, hwnd, icon->owner, icon->id);
+    return TRUE;
+}
+
+void WAYLAND_SystrayDockClear(HWND hwnd)
+{
+    /* Send NewIcon signal so panels refresh their display. */
+    struct sni_item *item;
+    pthread_mutex_lock(&sni_mutex);
+    LIST_FOR_EACH_ENTRY(item, &sni_list, struct sni_item, entry)
+    {
+        if (item->callback_hwnd == hwnd)
+        {
+            DBusMessage *sig = dbus_message_new_signal(
+                "/StatusNotifierItem", "org.kde.StatusNotifierItem", "NewIcon");
+            if (sig)
+            {
+                dbus_connection_send(item->conn, sig, NULL);
+                dbus_connection_flush(item->conn);
+                dbus_message_unref(sig);
+            }
+            break;
+        }
+    }
+    pthread_mutex_unlock(&sni_mutex);
+}
+
+BOOL WAYLAND_SystrayDockRemove(HWND hwnd)
+{
+    struct sni_item *item, *found = NULL;
+
+    pthread_mutex_lock(&sni_mutex);
+    LIST_FOR_EACH_ENTRY(item, &sni_list, struct sni_item, entry)
+    {
+        if (item->callback_hwnd == hwnd) { found = item; break; }
+    }
+    if (found) list_remove(&found->entry);
+    pthread_mutex_unlock(&sni_mutex);
+
+    if (!found) return FALSE;
+
+    found->running = FALSE;
+    pthread_join(found->dispatch_thread, NULL);
+    dbus_connection_close(found->conn);
+    dbus_connection_unref(found->conn);
+    free(found->icon_argb);
+    free(found);
+    return TRUE;
+}
+
+#else /* !HAVE_DBUS_DBUS_H */
+
+/* Graceful no-op fallback when D-Bus headers are absent at build time. */
+void WAYLAND_SystrayDockInit(HWND hwnd) {}
+
+BOOL WAYLAND_SystrayDockInsert(HWND hwnd, UINT cx, UINT cy, void *icon)
+{
+    return FALSE;
+}
+
+void WAYLAND_SystrayDockClear(HWND hwnd) {}
+
+BOOL WAYLAND_SystrayDockRemove(HWND hwnd)
+{
+    return FALSE;
+}
+
+#endif /* HAVE_DBUS_DBUS_H */
