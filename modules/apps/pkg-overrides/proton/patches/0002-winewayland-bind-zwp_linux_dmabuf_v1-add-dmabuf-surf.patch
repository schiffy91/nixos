diff --git a/server/wayland_dmabuf.c b/server/wayland_dmabuf.c
new file mode 100644
index 0000000..4def0d4
--- /dev/null
+++ b/server/wayland_dmabuf.c
@@ -0,0 +1,114 @@
+/*
+ * Wineserver: cross-process dmabuf fd broker for winewayland.drv
+ *
+ * Copyright 2025 scwhine for FRACTAL-NORTH
+ *
+ * Implements REQ_share_dmabuf_fd and REQ_get_dmabuf_fd.  The CEF GPU child
+ * exports its EGL framebuffer as a Linux dmabuf fd and calls share_dmabuf_fd
+ * to deposit it here.  The browser process (layered HWND owner) calls
+ * get_dmabuf_fd to retrieve the fd and attach it to its wl_surface.
+ *
+ * One entry is stored per HWND.  A new share_dmabuf_fd for the same HWND
+ * replaces the previous entry (old fd is closed).  get_dmabuf_fd consumes
+ * the entry (one-shot hand-off).
+ */
+
+#include "config.h"
+
+#include <stdlib.h>
+#include <unistd.h>
+
+#include "ntstatus.h"
+#define WIN32_NO_STATUS
+
+#include "handle.h"
+#include "process.h"
+#include "request.h"
+#include "thread.h"
+#include "wine/server_protocol.h"
+
+struct dmabuf_entry
+{
+    struct list       link;
+    user_handle_t     hwnd;
+    int               unix_fd;
+    int               width;
+    int               height;
+    unsigned int      format;
+    unsigned int      stride;
+    unsigned int      modifier_lo;
+    unsigned int      modifier_hi;
+};
+
+static struct list dmabuf_list = LIST_INIT(dmabuf_list);
+
+static struct dmabuf_entry *find_entry(user_handle_t hwnd)
+{
+    struct dmabuf_entry *e;
+    LIST_FOR_EACH_ENTRY(e, &dmabuf_list, struct dmabuf_entry, link)
+        if (e->hwnd == hwnd) return e;
+    return NULL;
+}
+
+/* REQ_share_dmabuf_fd: GPU child deposits its EGL framebuffer fd. */
+DECL_HANDLER(share_dmabuf_fd)
+{
+    struct dmabuf_entry *e;
+    int fd = thread_get_inflight_fd(current, req->fd);
+
+    if (fd == -1)
+    {
+        set_error(STATUS_INVALID_PARAMETER);
+        return;
+    }
+
+    /* Replace any existing entry for this HWND. */
+    if ((e = find_entry(req->hwnd)))
+    {
+        close(e->unix_fd);
+        list_remove(&e->link);
+    }
+    else if (!(e = malloc(sizeof(*e))))
+    {
+        close(fd);
+        set_error(STATUS_NO_MEMORY);
+        return;
+    }
+
+    e->hwnd        = req->hwnd;
+    e->unix_fd     = fd;
+    e->width       = req->width;
+    e->height      = req->height;
+    e->format      = req->format;
+    e->stride      = req->stride;
+    e->modifier_lo = req->modifier_lo;
+    e->modifier_hi = req->modifier_hi;
+    list_add_tail(&dmabuf_list, &e->link);
+}
+
+/* REQ_get_dmabuf_fd: browser retrieves the fd, consuming the entry. */
+DECL_HANDLER(get_dmabuf_fd)
+{
+    struct dmabuf_entry *e;
+
+    if (!(e = find_entry(req->hwnd)))
+    {
+        set_error(STATUS_NOT_FOUND);
+        return;
+    }
+
+    reply->width       = e->width;
+    reply->height      = e->height;
+    reply->format      = e->format;
+    reply->stride      = e->stride;
+    reply->modifier_lo = e->modifier_lo;
+    reply->modifier_hi = e->modifier_hi;
+
+    /* Send the unix fd to the client.  SERVER_PROTOCOL_VERSION is used as the
+     * dummy handle value; the client calls wine_server_recv_fd(reply->fd). */
+    send_client_fd(current->process, e->unix_fd, SERVER_PROTOCOL_VERSION);
+    reply->fd = e->unix_fd;  /* client matches on this value via recv_fd */
+
+    list_remove(&e->link);
+    free(e);
+}
