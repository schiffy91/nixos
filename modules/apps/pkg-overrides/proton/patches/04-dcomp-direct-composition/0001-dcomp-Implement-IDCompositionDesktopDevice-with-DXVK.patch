+/* Gather Vulkan handles from DXVK and post them to winewayland.drv via SendMessageW
+ * to do the actual export work using native libvulkan (wine's vulkan-1.dll can't
+ * operate on DXVK-tracked device handles). */
+static void wayland_compose_export_visual(struct dcomp_target *t, struct dcomp_visual *v)
+{
+    IDXGISwapChain1 *sc = NULL;
+    IDCompositionSurface *cs = NULL;
+    ID3D11Texture2D *bb = NULL;
+    IDXGIVkInteropSurface *iface_surf = NULL;
+    IDXGIVkInteropDevice *iface_dev = NULL;
+    VkImage src_img = 0;
+    VkImageLayout src_layout = VK_IMAGE_LAYOUT_UNDEFINED;
+    VkImageCreateInfo src_info = { VK_STRUCTURE_TYPE_IMAGE_CREATE_INFO, NULL };
+    VkInstance vk_inst = NULL; VkPhysicalDevice vk_pdev = NULL; VkDevice vk_dev = NULL;
+    VkQueue vk_queue = NULL; uint32_t queue_family = 0;
+    HRESULT hr;
+
+    TRACE("export visual=%p content=%p hwnd=%p\n", v, v->content, t->hwnd);
+    if (!v->content) return;
+
+    /* CEF emits two flavors of content on Visuals:
+     *   1) IDXGISwapChain1   — used for popups / hardware overlays (GetBuffer(0) is the latest frame)
+     *   2) IDCompositionSurface — used for the main view (draw_texture is the latest frame
+     *      after BeginDraw → render → EndDraw → Commit)
+     * Both eventually need to become a dmabuf attached to our wl_surface. */
+    if (SUCCEEDED(IUnknown_QueryInterface(v->content, &IID_IDXGISwapChain1, (void **)&sc)) && sc)
+    {
+        if (FAILED(hr = IDXGISwapChain1_GetBuffer(sc, 0, &IID_ID3D11Texture2D, (void **)&bb)) || !bb)
+        { WARN("  GetBuffer failed hr=%#lx\n", hr); IDXGISwapChain1_Release(sc); return; }
+    }
+    else if (SUCCEEDED(IUnknown_QueryInterface(v->content, &IID_IDCompositionSurface, (void **)&cs)) && cs)
+    {
+        struct dcomp_surface *s = impl_from_IDCompositionSurface(cs);
+        if (!s->draw_texture) { IDCompositionSurface_Release(cs); return; }
+        bb = s->draw_texture;
+        ID3D11Texture2D_AddRef(bb);
+    }
+    else
+    { WARN("  unknown content type — not swap chain or composition surface\n"); return; }
+
+    if (FAILED(hr = ID3D11Texture2D_QueryInterface(bb, &IID_IDXGIVkInteropSurface, (void **)&iface_surf)) || !iface_surf)
+    { WARN("  no IDXGIVkInteropSurface hr=%#lx (DXVK not active?)\n", hr);
+      ID3D11Texture2D_Release(bb); if (cs) IDCompositionSurface_Release(cs); if (sc) IDXGISwapChain1_Release(sc); return; }
+    if (FAILED(hr = iface_surf->lpVtbl->GetVulkanImageInfo(iface_surf, &src_img, &src_layout, &src_info)))
+    { WARN("  GetVulkanImageInfo failed hr=%#lx\n", hr); iface_surf->lpVtbl->Release(iface_surf); ID3D11Texture2D_Release(bb); if (cs) IDCompositionSurface_Release(cs); if (sc) IDXGISwapChain1_Release(sc); return; }
+    TRACE("  src VkImage=0x%llx fmt=%d extent=%ux%u layout=%d\n",
+          (unsigned long long)src_img, src_info.format,
+          src_info.extent.width, src_info.extent.height, src_layout);
+    if (FAILED(hr = iface_surf->lpVtbl->GetDevice(iface_surf, &iface_dev)) || !iface_dev)
+    { WARN("  GetDevice failed hr=%#lx\n", hr); iface_surf->lpVtbl->Release(iface_surf); ID3D11Texture2D_Release(bb); if (cs) IDCompositionSurface_Release(cs); if (sc) IDXGISwapChain1_Release(sc); return; }
+
+    iface_dev->lpVtbl->GetVulkanHandles(iface_dev, &vk_inst, &vk_pdev, &vk_dev);
+    iface_dev->lpVtbl->GetSubmissionQueue(iface_dev, &vk_queue, &queue_family);
+    TRACE("  vk_dev=%p vk_pdev=%p vk_queue=%p queue_family=%u src_image=0x%llx fmt=%d\n",
+          vk_dev, vk_pdev, vk_queue, queue_family,
+          (unsigned long long)src_img, src_info.format);
+
+    /* Hold DXVK's submission lock around the unix-side queue submit so we don't
+     * race CEF's own vkQueueSubmit calls (Vulkan vkQueueSubmit is not thread
+     * safe per-queue, and removing this lock crashed CEF inside wine vulkan
+     * thunks). */
+    iface_dev->lpVtbl->LockSubmissionQueue(iface_dev);
+    {
+        struct wayland_compose_attach_request req = {0};
+        req.src_image          = (uint64_t)src_img;
+        req.src_layout         = (uint32_t)src_layout;
+        req.vk_format          = (uint32_t)src_info.format;
+        req.width              = src_info.extent.width;
+        req.height             = src_info.extent.height;
+        req.vk_instance        = (uint64_t)(uintptr_t)vk_inst;
+        req.vk_physical_device = (uint64_t)(uintptr_t)vk_pdev;
+        req.vk_device          = (uint64_t)(uintptr_t)vk_dev;
+        req.vk_queue           = (uint64_t)(uintptr_t)vk_queue;
+        req.queue_family       = queue_family;
+        req.target_hwnd        = t->hwnd;     /* the DComp target's HWND */
+        TRACE("hwnd=%p %ux%u fmt=%d src_image=0x%llx\n",
+              t->hwnd, req.width, req.height, req.vk_format, (unsigned long long)req.src_image);
+        /* SendMessage to the ticker thread's own hidden HWND_MESSAGE window.
+         * Because the destination HWND lives on THIS thread, wine's user32
+         * dispatches the wndproc inline on this thread (the dcomp ticker)
+         * rather than queuing to the original target_hwnd's owner thread.
+         * That keeps the GPU work (vkSubmit + vkWaitForFences + memcpy +
+         * wayland_commit) off BNet's UI thread, so CEF's input message pump
+         * and Mojo IPC dispatch stay responsive. */
+        /* SendMessageTimeoutW to the DComp target's HWND so the wndproc
+         * dispatch flows through the user32 driver hook to wayland's
+         * WindowMessage handler. SMTO_ABORTIFHUNG + 50ms timeout bounds how
+         * long a hung target window's thread can keep us blocked. */
+        DWORD_PTR sm_result = 0;
+        SendMessageTimeoutW(t->hwnd, WM_WAYLAND_COMPOSE_ATTACH, 0, (LPARAM)&req,
+                            SMTO_NORMAL | SMTO_ABORTIFHUNG, 50, &sm_result);
+    }
+    iface_dev->lpVtbl->ReleaseSubmissionQueue(iface_dev);
+
+    if (iface_dev)  iface_dev->lpVtbl->Release(iface_dev);
+    if (iface_surf) iface_surf->lpVtbl->Release(iface_surf);
+    if (bb)         ID3D11Texture2D_Release(bb);
+    if (cs)         IDCompositionSurface_Release(cs);
+    if (sc)         IDXGISwapChain1_Release(sc);
 }
 
