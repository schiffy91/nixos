+#define VISUAL_STUB_OK(name, ...) \
+    static HRESULT WINAPI visual_##name(IDCompositionVisual2 *iface, ##__VA_ARGS__) \
+    { struct dcomp_visual *v = impl_from_IDCompositionVisual2(iface); v->dirty = TRUE; return S_OK; }
