+static BOOL load_vulkan_once(void)
+{
+    static LONG state = 0;  /* 0=untried, 1=ok, 2=failed */
+    LONG s = InterlockedCompareExchange(&state, 0, 0);
+    if (s == 1) return TRUE;
+    if (s == 2) return FALSE;
+    g_vulkan = LoadLibraryW(L"vulkan-1.dll");
+    if (!g_vulkan) { ERR("vulkan-1.dll load failed\n"); InterlockedExchange(&state, 2); return FALSE; }
+    LOADVK(vkGetInstanceProcAddr);
+    LOADVK(vkGetDeviceProcAddr);
+    LOADVK(vkAllocateCommandBuffers);
+    LOADVK(vkAllocateMemory);
+    LOADVK(vkBeginCommandBuffer);
+    LOADVK(vkBindImageMemory);
+    LOADVK(vkCmdCopyImage);
+    LOADVK(vkCmdPipelineBarrier);
+    LOADVK(vkCreateCommandPool);
+    LOADVK(vkCreateFence);
+    LOADVK(vkCreateImage);
+    LOADVK(vkDestroyFence);
+    LOADVK(vkDestroyImage);
+    LOADVK(vkFreeMemory);
+    LOADVK(vkEndCommandBuffer);
+    LOADVK(vkGetImageMemoryRequirements2);
+    LOADVK(vkGetPhysicalDeviceMemoryProperties);
+    LOADVK(vkQueueSubmit);
+    LOADVK(vkResetCommandBuffer);
+    LOADVK(vkResetFences);
+    LOADVK(vkWaitForFences);
+    /* vkGetMemoryFdKHR is a device-level extension fn */
+    InterlockedExchange(&state, 1);
+    return TRUE;
 }
 
-HRESULT WINAPI DCompositionCreateDevice2(IUnknown *rendering_device, REFIID iid, void **device)
+/* ───── per-visual exportable surface state (cached across Commits) ───── */
+struct wayland_compose_export
