+struct dcomp_device
+{
+    IDCompositionDesktopDevice IDCompositionDesktopDevice_iface;
+    LONG ref;
+
+    IUnknown        *rendering_device;     /* AddRef'd; usually an ID3D11Device */
+    ID3D11Device    *d3d11_device;         /* QI'd from rendering_device; NULL if not D3D11 */
+    struct list      targets;              /* live IDCompositionTarget list */
+    struct list      visuals;              /* live IDCompositionVisual list */
+    struct list      surfaces;             /* live IDCompositionSurface list */
+    BOOL             pending_commit;
+
+    /* : continuous re-export ticker. CEF Commits once but Presents every frame
+     * on the swap chain bound into the visual tree, so a single Commit-time export
+     * freezes the first frame. The ticker thread walks the live tree at ~60Hz and
+     * re-runs the export pipeline, which on the unix side re-copies the latest src
+     * VkImage into our exportable dst_image and re-attaches the wl_buffer. */
+    HANDLE           tick_thread;
+    HANDLE           tick_stop;
+    /* Hidden HWND_MESSAGE window owned by the ticker thread itself. We
+     * SendMessage to this rather than the DComp target's HWND so the
+     * WM_WAYLAND_COMPOSE_ATTACH wndproc dispatch runs inline on the
+     * ticker thread, keeping the GPU+wayland work off BNet's UI thread. */
+    HWND             ticker_hwnd;
+    CRITICAL_SECTION cs;
+    BOOL             cs_init;
+};
+
+struct dcomp_visual
+{
+    IDCompositionVisual2 IDCompositionVisual2_iface;
+    LONG ref;
+    struct list entry;
+    struct dcomp_device *device;
+
+    IUnknown *content;                     /* AddRef'd; usually a swap chain or dcomp_surface */
+    float offset_x, offset_y;
+    D2D_MATRIX_3X2_F transform;
+    struct list children;
+    struct list child_entry;               /* link in parent->children */
+    struct dcomp_visual *parent;
+    BOOL dirty;
+
+    /* state: persistent across Commits, recreated on resize */
+    struct wayland_compose_export exp;
+};
+
+struct dcomp_surface
+{
+    IDCompositionSurface IDCompositionSurface_iface;
+    LONG ref;
+    struct list entry;
+    struct dcomp_device *device;
+
+    UINT width, height;
+    DXGI_FORMAT format;
+    DXGI_ALPHA_MODE alpha_mode;
+    ID3D11Texture2D *draw_texture;         /* allocated lazily in BeginDraw */
+    BOOL in_draw;
+};
+
+struct dcomp_target
+{
+    IDCompositionTarget IDCompositionTarget_iface;
+    LONG ref;
+    struct list entry;
+    struct dcomp_device *device;
+
+    HWND hwnd;
+    BOOL topmost;
+    struct dcomp_visual *root;             /* AddRef'd; may be NULL */
+};
+
+/* impl_from_X helpers */
+static inline struct dcomp_device *impl_from_IDCompositionDesktopDevice(IDCompositionDesktopDevice *iface)
+    { return CONTAINING_RECORD(iface, struct dcomp_device, IDCompositionDesktopDevice_iface); }
+static inline struct dcomp_visual *impl_from_IDCompositionVisual2(IDCompositionVisual2 *iface)
+    { return CONTAINING_RECORD(iface, struct dcomp_visual, IDCompositionVisual2_iface); }
+static inline struct dcomp_surface *impl_from_IDCompositionSurface(IDCompositionSurface *iface)
+    { return CONTAINING_RECORD(iface, struct dcomp_surface, IDCompositionSurface_iface); }
+static inline struct dcomp_target *impl_from_IDCompositionTarget(IDCompositionTarget *iface)
+    { return CONTAINING_RECORD(iface, struct dcomp_target, IDCompositionTarget_iface); }
+
+/* forward vtable declarations */
+static const IDCompositionDesktopDeviceVtbl dcomp_device_vtbl;
+static const IDCompositionVisual2Vtbl       dcomp_visual_vtbl;
+static const IDCompositionSurfaceVtbl       dcomp_surface_vtbl;
+static const IDCompositionTargetVtbl        dcomp_target_vtbl;
+
+/* ─────────────────────── object constructors ─────────────────────── */
+
+static struct dcomp_visual *dcomp_visual_create(struct dcomp_device *device)
+{
+    struct dcomp_visual *v = calloc(1, sizeof(*v));
+    if (!v) return NULL;
+    v->IDCompositionVisual2_iface.lpVtbl = &dcomp_visual_vtbl;
+    v->ref = 1;
+    v->device = device;
+    v->transform.m11 = v->transform.m22 = 1.0f;
+    v->exp.dmabuf_fd = -1;
+    list_init(&v->children);
+    list_add_tail(&device->visuals, &v->entry);
+    TRACE("created visual %p\n", v);
+    return v;
+}
+
+static struct dcomp_surface *dcomp_surface_create(struct dcomp_device *device,
+                                                  UINT width, UINT height,
+                                                  DXGI_FORMAT format, DXGI_ALPHA_MODE alpha)
+{
+    struct dcomp_surface *s = calloc(1, sizeof(*s));
+    if (!s) return NULL;
+    s->IDCompositionSurface_iface.lpVtbl = &dcomp_surface_vtbl;
+    s->ref = 1;
+    s->device = device;
+    s->width = width;
+    s->height = height;
+    s->format = format;
+    s->alpha_mode = alpha;
+    list_add_tail(&device->surfaces, &s->entry);
+    TRACE("created surface %p (%ux%u fmt=%u alpha=%u)\n", s, width, height, format, alpha);
+    return s;
+}
+
+static struct dcomp_target *dcomp_target_create(struct dcomp_device *device,
+                                                HWND hwnd, BOOL topmost)
+{
+    struct dcomp_target *t = calloc(1, sizeof(*t));
+    if (!t) return NULL;
+    t->IDCompositionTarget_iface.lpVtbl = &dcomp_target_vtbl;
+    t->ref = 2;     /* one for caller, one retained by device->targets list */
+    t->device = device;
+    t->hwnd = hwnd;
+    t->topmost = topmost;
+    list_add_tail(&device->targets, &t->entry);
+    TRACE("created target %p (hwnd=%p topmost=%d) device=%p\n", t, hwnd, topmost, device);
+    return t;
+}
