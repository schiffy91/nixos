+static HRESULT WINAPI device_QueryInterface(IDCompositionDesktopDevice *iface, REFIID iid, void **out)
+{
+    if (IsEqualGUID(iid, &IID_IUnknown) ||
+        IsEqualGUID(iid, &IID_IDCompositionDevice2) ||
+        IsEqualGUID(iid, &IID_IDCompositionDesktopDevice))
+    { IDCompositionDesktopDevice_AddRef(iface); *out = iface; return S_OK; }
+    WARN("device QI %s — not supported\n", debugstr_guid(iid));
+    *out = NULL;
+    return E_NOINTERFACE;
+}
+
+static ULONG WINAPI device_AddRef(IDCompositionDesktopDevice *iface)
+{ struct dcomp_device *d = impl_from_IDCompositionDesktopDevice(iface); return InterlockedIncrement(&d->ref); }
+
+static ULONG WINAPI device_Release(IDCompositionDesktopDevice *iface)
+{
+    struct dcomp_device *d = impl_from_IDCompositionDesktopDevice(iface);
+    ULONG r = InterlockedDecrement(&d->ref);
+    if (!r)
+    {
+        struct dcomp_target *t, *t_next;
+        if (d->tick_stop)   SetEvent(d->tick_stop);
+        if (d->tick_thread) { WaitForSingleObject(d->tick_thread, 1000); CloseHandle(d->tick_thread); }
+        if (d->tick_stop)   CloseHandle(d->tick_stop);
+        LIST_FOR_EACH_ENTRY_SAFE(t, t_next, &d->targets, struct dcomp_target, entry)
+            IDCompositionTarget_Release(&t->IDCompositionTarget_iface);
+        if (d->cs_init) DeleteCriticalSection(&d->cs);
+        if (d->d3d11_device) ID3D11Device_Release(d->d3d11_device);
+        if (d->rendering_device) IUnknown_Release(d->rendering_device);
+        free(d);
+    }
+    return r;
+}
