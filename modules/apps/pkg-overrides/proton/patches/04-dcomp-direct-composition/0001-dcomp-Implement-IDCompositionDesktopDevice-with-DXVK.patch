-    FIXME("%p, %s, %p.\n", rendering_device, debugstr_guid(iid), device);
+    /* Intermediate D3D11 texture: copy target for the (possibly opaque) swap-chain back
+     * buffer. Created via ID3D11Device::CreateTexture2D so QI for IDXGIVkInteropSurface
+     * is guaranteed to work even when the swap chain's own back buffer hides its VkImage. */
+    ID3D11Texture2D *intermediate;
+    VkImage          intermediate_vk;        /* VkImage of intermediate, queried via interop */
+    /* Exportable copy backed by VK_EXT_external_memory_dma_buf for compositor attach */
+    VkImage          image;
+    VkDeviceMemory   memory;
+    VkDevice         device;
+    uint32_t         width, height;
+    VkFormat         format;
+    int              dmabuf_fd;
+    uint32_t         stride;
+    BOOL             valid;
+};
 
-    /* Try to workaround Chromium race fixed by Chromium commit 1c13c9105b40e83f87ebcad104fab57fcef43eb9. */
-    Sleep(50);
+static void wayland_compose_export_destroy(struct wayland_compose_export *e)
+{
+    if (!e) return;
+    if (e->intermediate) { ID3D11Texture2D_Release(e->intermediate); e->intermediate = NULL; }
+    if (e->valid)
+    {
+        if (e->image && p_vkDestroyImage) p_vkDestroyImage(e->device, e->image, NULL);
+        if (e->memory && p_vkFreeMemory)  p_vkFreeMemory(e->device, e->memory, NULL);
+    }
+    /* dmabuf_fd is owned by winewayland.drv-side wl_buffer (dup'd on attach);
+     * we let wine's handle table clean it on process exit. */
+    memset(e, 0, sizeof(*e));
+    e->dmabuf_fd = -1;
+}
 
