+    device_CreateTargetForHwnd, device_CreateSurfaceFromHandle, device_CreateSurfaceFromHwnd,
+};
+
+/* ─────────────────────── dll entry points ─────────────────────── */
+
+static HRESULT dcomp_create_device(IUnknown *rendering_device, REFIID iid, void **out)
+{
+    struct dcomp_device *d;
+    HRESULT hr;
+
+    if (!out) return E_POINTER;
+    *out = NULL;
+
+    if (!IsEqualGUID(iid, &IID_IDCompositionDevice2) &&
+        !IsEqualGUID(iid, &IID_IDCompositionDesktopDevice) &&
+        !IsEqualGUID(iid, &IID_IUnknown))
+    {
+        FIXME("unsupported iid %s\n", debugstr_guid(iid));
+        return E_NOINTERFACE;
+    }
+
+    d = calloc(1, sizeof(*d));
+    if (!d) return E_OUTOFMEMORY;
+    d->IDCompositionDesktopDevice_iface.lpVtbl = &dcomp_device_vtbl;
+    d->ref = 1;
+    list_init(&d->targets);
+    list_init(&d->visuals);
+    list_init(&d->surfaces);
+    InitializeCriticalSection(&d->cs);
+    d->cs_init = TRUE;
+
+    if (rendering_device)
+    {
+        d->rendering_device = rendering_device;
+        IUnknown_AddRef(rendering_device);
+        hr = IUnknown_QueryInterface(rendering_device, &IID_ID3D11Device, (void **)&d->d3d11_device);
+        if (FAILED(hr))
+        {
+            WARN("rendering_device is not ID3D11Device hr=%#lx (BeginDraw will fail)\n", hr);
+            d->d3d11_device = NULL;
+        }
+    }
+
+    /* Ticker thread — bounded by SendMessageTimeoutW(50ms) so it cannot wedge
+     * CEF's main thread. CEF only Commits once but Presents every frame on the
+     * swap chain bound into the visual tree, so without the ticker the
+     * displayed content freezes at the first frame. */
+    d->tick_stop = CreateEventW(NULL, TRUE, FALSE, NULL);
+    /* WINE_DCOMP_NO_TICK=1 disables the dcomp ticker (useful for
+     * debugging whether the ticker is starving CEF's input message pump). */
+    if (!getenv("WINE_DCOMP_NO_TICK"))
+    {
+        d->tick_thread = CreateThread(NULL, 0, wayland_compose_tick_thread, d, 0, NULL);
+        if (!d->tick_thread) WARN(" ticker thread creation failed\n");
+    }
+    else TRACE("dcomp: ticker disabled via WINE_DCOMP_NO_TICK\n");
+
+    *out = &d->IDCompositionDesktopDevice_iface;
+    TRACE("created device=%p (d3d11=%p ticker=%p)\n", d, d->d3d11_device, d->tick_thread);
+    return S_OK;
+}
+
+HRESULT WINAPI DCompositionCreateDevice(IDXGIDevice *dxgi_device, REFIID iid, void **out)
+{
+    TRACE("%p %s %p\n", dxgi_device, debugstr_guid(iid), out);
+    return dcomp_create_device((IUnknown *)dxgi_device, iid, out);
+}
+
+HRESULT WINAPI DCompositionCreateDevice2(IUnknown *rendering_device, REFIID iid, void **out)
+{
+    TRACE("%p %s %p\n", rendering_device, debugstr_guid(iid), out);
+    return dcomp_create_device(rendering_device, iid, out);
+}
+
+HRESULT WINAPI DCompositionCreateDevice3(IUnknown *rendering_device, REFIID iid, void **out)
+{
+    TRACE("%p %s %p\n", rendering_device, debugstr_guid(iid), out);
+    return dcomp_create_device(rendering_device, iid, out);
+}

