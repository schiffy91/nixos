+VISUAL_STUB_OK(SetOffsetYAnimation, IDCompositionAnimation *a)
+static HRESULT WINAPI visual_SetTransform(IDCompositionVisual2 *iface, const D2D_MATRIX_3X2_F *m)
+{ struct dcomp_visual *v = impl_from_IDCompositionVisual2(iface); if (m) v->transform = *m; v->dirty = TRUE; return S_OK; }
+VISUAL_STUB_OK(SetTransformObject, IDCompositionTransform *t)
+VISUAL_STUB_OK(SetTransformParent, IDCompositionVisual *p)
+VISUAL_STUB_OK(SetEffect, IDCompositionEffect *e)
+VISUAL_STUB_OK(SetBitmapInterpolationMode, enum DCOMPOSITION_BITMAP_INTERPOLATION_MODE m)
+VISUAL_STUB_OK(SetBorderMode, enum DCOMPOSITION_BORDER_MODE m)
