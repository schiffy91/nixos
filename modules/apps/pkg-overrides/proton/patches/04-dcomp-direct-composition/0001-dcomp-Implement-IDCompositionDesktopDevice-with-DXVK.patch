+/* Build or refresh visual->exp so it has an exportable VkImage matching the src
+ * texture's dims/format. Returns TRUE on success. */
+static BOOL wayland_compose_export_ensure(struct dcomp_visual *v, VkDevice dev, VkPhysicalDevice pdev,
+                                  const VkImageCreateInfo *src_info, uint32_t *drm_format_out)
+{
+    VkImageCreateInfo ci;
+    VkExternalMemoryImageCreateInfo eci = { VK_STRUCTURE_TYPE_EXTERNAL_MEMORY_IMAGE_CREATE_INFO, NULL,
+                                            VK_EXTERNAL_MEMORY_HANDLE_TYPE_DMA_BUF_BIT_EXT };
+    VkImageMemoryRequirementsInfo2 ri = { VK_STRUCTURE_TYPE_IMAGE_MEMORY_REQUIREMENTS_INFO_2 };
+    VkMemoryRequirements2 mreq = { VK_STRUCTURE_TYPE_MEMORY_REQUIREMENTS_2 };
+    VkMemoryDedicatedRequirements dreq = { VK_STRUCTURE_TYPE_MEMORY_DEDICATED_REQUIREMENTS };
+    VkMemoryDedicatedAllocateInfo dai = { VK_STRUCTURE_TYPE_MEMORY_DEDICATED_ALLOCATE_INFO };
+    VkExportMemoryAllocateInfo eai = { VK_STRUCTURE_TYPE_EXPORT_MEMORY_ALLOCATE_INFO, NULL,
+                                       VK_EXTERNAL_MEMORY_HANDLE_TYPE_DMA_BUF_BIT_EXT };
+    VkMemoryAllocateInfo ai = { VK_STRUCTURE_TYPE_MEMORY_ALLOCATE_INFO };
+    VkMemoryGetFdInfoKHR gfi = { VK_STRUCTURE_TYPE_MEMORY_GET_FD_INFO_KHR };
+    int memtype, fd = -1;
+    BOOL opaque;
+
+    WARN("ENSURE: src fmt=%d ext=%ux%u valid=%d\n", src_info->format, src_info->extent.width, src_info->extent.height, v->exp.valid);
+
+    *drm_format_out = dxgi_to_drm_fourcc((DXGI_FORMAT)0, &opaque);
+    /* Map src VkFormat back to a DRM fourcc */
+    if (src_info->format == VK_FORMAT_B8G8R8A8_UNORM)         *drm_format_out = DRM_FORMAT_ARGB8888;
+    else if (src_info->format == VK_FORMAT_R8G8B8A8_UNORM)    *drm_format_out = DRM_FORMAT_ABGR8888;
+    else if (src_info->format == VK_FORMAT_A2R10G10B10_UNORM_PACK32) *drm_format_out = DRM_FORMAT_ABGR2101010;
+    else if (src_info->format == VK_FORMAT_R16G16B16A16_SFLOAT)     *drm_format_out = DRM_FORMAT_ABGR16161616F;
+    else { ERR("unsupported VkFormat %d\n", src_info->format); return FALSE; }
+
+    if (v->exp.valid && v->exp.image != 0 && v->exp.device == dev &&
+        v->exp.width == src_info->extent.width && v->exp.height == src_info->extent.height &&
+        v->exp.format == src_info->format)
+        return TRUE;        /* reuse */
+
+    wayland_compose_export_destroy(&v->exp);
+    v->exp.device = dev;
+
+    ci = *src_info;
+    ci.pNext = &eci;
+    ci.tiling = VK_IMAGE_TILING_OPTIMAL;
+    ci.usage  = VK_IMAGE_USAGE_TRANSFER_DST_BIT | VK_IMAGE_USAGE_SAMPLED_BIT;
+    ci.initialLayout = VK_IMAGE_LAYOUT_UNDEFINED;
+    ci.mipLevels = 1;
+    ci.arrayLayers = 1;
+    ci.samples = VK_SAMPLE_COUNT_1_BIT;
+    ci.sharingMode = VK_SHARING_MODE_EXCLUSIVE;
+    ci.queueFamilyIndexCount = 0;
+    ci.pQueueFamilyIndices = NULL;
+
+    if (p_vkCreateImage(dev, &ci, NULL, &v->exp.image) != VK_SUCCESS)
+    { ERR("vkCreateImage failed\n"); return FALSE; }
+
+    ri.image = v->exp.image;
+    mreq.pNext = &dreq;
+    p_vkGetImageMemoryRequirements2(dev, &ri, &mreq);
+
+    memtype = pick_memory_type(pdev, mreq.memoryRequirements.memoryTypeBits, VK_MEMORY_PROPERTY_DEVICE_LOCAL_BIT);
+    if (memtype < 0) { ERR("no suitable memory type\n"); wayland_compose_export_destroy(&v->exp); return FALSE; }
+
+    if (dreq.requiresDedicatedAllocation || dreq.prefersDedicatedAllocation)
+    {
+        dai.image = v->exp.image;
+        dai.pNext = &eai;
+        ai.pNext  = &dai;
+    }
+    else ai.pNext = &eai;
+    ai.allocationSize  = mreq.memoryRequirements.size;
+    ai.memoryTypeIndex = memtype;
+    if (p_vkAllocateMemory(dev, &ai, NULL, &v->exp.memory) != VK_SUCCESS)
+    { ERR("vkAllocateMemory exportable failed\n"); wayland_compose_export_destroy(&v->exp); return FALSE; }
+    if (p_vkBindImageMemory(dev, v->exp.image, v->exp.memory, 0) != VK_SUCCESS)
+    { ERR("vkBindImageMemory failed\n"); wayland_compose_export_destroy(&v->exp); return FALSE; }
+
+    if (!p_vkGetMemoryFdKHR)
+        p_vkGetMemoryFdKHR = (void *)p_vkGetDeviceProcAddr(dev, "vkGetMemoryFdKHR");
+    if (!p_vkGetMemoryFdKHR) { ERR("vkGetMemoryFdKHR not found\n"); wayland_compose_export_destroy(&v->exp); return FALSE; }
+    gfi.memory     = v->exp.memory;
+    gfi.handleType = VK_EXTERNAL_MEMORY_HANDLE_TYPE_DMA_BUF_BIT_EXT;
+    if (p_vkGetMemoryFdKHR(dev, &gfi, &fd) != VK_SUCCESS || fd < 0)
+    { ERR("vkGetMemoryFdKHR failed\n"); wayland_compose_export_destroy(&v->exp); return FALSE; }
+
+    v->exp.dmabuf_fd = fd;
+    v->exp.width     = src_info->extent.width;
+    v->exp.height    = src_info->extent.height;
+    v->exp.format    = src_info->format;
+    v->exp.stride    = src_info->extent.width * 4;   /* assume 32bpp; refined by importer */
+    v->exp.valid     = TRUE;
+
+    TRACE("allocated exportable VkImage %p (%ux%u fmt=%d) memory=%p dmabuf_fd=%d\n",
+          v->exp.image, v->exp.width, v->exp.height, src_info->format,
+          v->exp.memory, fd);
+    return TRUE;
+}
