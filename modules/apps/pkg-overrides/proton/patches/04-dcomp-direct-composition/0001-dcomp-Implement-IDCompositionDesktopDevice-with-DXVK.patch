+        if (t->root) IDCompositionVisual2_Release(&t->root->IDCompositionVisual2_iface);
+        list_remove(&t->entry);
+        if (d && d->cs_init) LeaveCriticalSection(&d->cs);
+        free(t);
+    }
+    return r;
+}
