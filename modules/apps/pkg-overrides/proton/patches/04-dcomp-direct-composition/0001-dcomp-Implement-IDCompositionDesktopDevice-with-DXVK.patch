+
+static HRESULT WINAPI visual_QueryInterface(IDCompositionVisual2 *iface, REFIID iid, void **out)
+{
+    if (IsEqualGUID(iid, &IID_IUnknown) ||
+        IsEqualGUID(iid, &IID_IDCompositionVisual) ||
+        IsEqualGUID(iid, &IID_IDCompositionVisual2))
+    {
+        IDCompositionVisual2_AddRef(iface);
+        *out = iface;
+        return S_OK;
+    }
+    WARN("visual QI %s — not supported\n", debugstr_guid(iid));
+    *out = NULL;
+    return E_NOINTERFACE;
+}
+
+static ULONG WINAPI visual_AddRef(IDCompositionVisual2 *iface)
+{
+    struct dcomp_visual *v = impl_from_IDCompositionVisual2(iface);
+    return InterlockedIncrement(&v->ref);
+}
+
+static ULONG WINAPI visual_Release(IDCompositionVisual2 *iface)
+{
+    struct dcomp_visual *v = impl_from_IDCompositionVisual2(iface);
+    ULONG r = InterlockedDecrement(&v->ref);
+    if (!r)
+    {
+        struct dcomp_visual *c, *cn;
+        LIST_FOR_EACH_ENTRY_SAFE(c, cn, &v->children, struct dcomp_visual, child_entry)
+        { list_remove(&c->child_entry); c->parent = NULL; }
+        if (v->parent) list_remove(&v->child_entry);
+        wayland_compose_export_destroy(&v->exp);
+        if (v->content) IUnknown_Release(v->content);
+        list_remove(&v->entry);
+        free(v);
+    }
+    return r;
+}
