+/* Custom wndproc that explicitly routes driver messages to the wayland
+ * driver. wine's default window proc routes WM_WINE_*_DRIVER_MSG to
+ * user_driver->pWindowMessage, but built-in classes (Static, etc.) handle
+ * their own message dispatch and never reach DefWindowProc for these
+ * messages, so we need a dedicated wndproc here. */
+static LRESULT CALLBACK wayland_compose_ticker_wndproc(HWND hwnd, UINT msg,
+                                               WPARAM wp, LPARAM lp)
+{
+    /* Pass everything to DefWindowProcW — for messages in the WM_WINE_*
+     * driver range, that routes them to user_driver->pWindowMessage, which
+     * is wayland's WAYLAND_WindowMessage → wayland_compose_handle_attach. */
+    return DefWindowProcW(hwnd, msg, wp, lp);
+}
