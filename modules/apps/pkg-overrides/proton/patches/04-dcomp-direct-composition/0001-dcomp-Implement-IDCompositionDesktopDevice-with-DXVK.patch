+static HRESULT WINAPI target_SetRoot(IDCompositionTarget *iface, IDCompositionVisual *visual)
+{
+    struct dcomp_target *t = impl_from_IDCompositionTarget(iface);
+    TRACE("target=%p visual=%p (hwnd=%p)\n", t, visual, t->hwnd);
+    if (t->device && t->device->cs_init) EnterCriticalSection(&t->device->cs);
+    if (t->root) IDCompositionVisual2_Release(&t->root->IDCompositionVisual2_iface);
+    t->root = NULL;
+    if (visual)
+    {
+        IDCompositionVisual2 *v2 = NULL;
+        if (SUCCEEDED(IDCompositionVisual_QueryInterface(visual, &IID_IDCompositionVisual2, (void **)&v2)) && v2)
+            t->root = impl_from_IDCompositionVisual2(v2);
+    }
+    if (t->device) t->device->pending_commit = TRUE;
+    if (t->device && t->device->cs_init) LeaveCriticalSection(&t->device->cs);
+    return S_OK;
