+static ULONG WINAPI target_AddRef(IDCompositionTarget *iface)
+{ struct dcomp_target *t = impl_from_IDCompositionTarget(iface); return InterlockedIncrement(&t->ref); }
+
+static ULONG WINAPI target_Release(IDCompositionTarget *iface)
+{
+    struct dcomp_target *t = impl_from_IDCompositionTarget(iface);
+    ULONG r = InterlockedDecrement(&t->ref);
+    if (!r)
+    {
+        struct dcomp_device *d = t->device;
