+static DWORD WINAPI wayland_compose_tick_thread(void *arg)
+{
+    struct dcomp_device *d = arg;
+    WNDCLASSW wc = {0};
+    static const WCHAR class_name[] = L"wine_dcomp_ticker_class";
+
+    TRACE(" ticker started device=%p\n", d);
+
+    /* Register a private window class with our wndproc so driver messages
+     * get routed through DefWindowProcW → user_driver->pWindowMessage. */
+    wc.lpfnWndProc = wayland_compose_ticker_wndproc;
+    wc.lpszClassName = class_name;
+    RegisterClassW(&wc);     /* idempotent — class may already be registered */
 
+    /* Create a hidden HWND_MESSAGE window owned by THIS thread. SendMessage
+     * to a window whose owner thread is the caller dispatches the wndproc
+     * inline (no thread switch) — so WM_WAYLAND_COMPOSE_ATTACH lands
+     * on wayland's WindowMessage handler on the ticker thread, not on
+     * BNet's UI thread. That keeps the per-frame GPU + wayland work off
+     * BNet's UI thread (which has to keep dispatching mouse/keyboard/IPC). */
+    d->ticker_hwnd = CreateWindowExW(0, class_name, L"-ticker",
+                                     0, 0, 0, 0, 0,
+                                     HWND_MESSAGE, NULL, NULL, NULL);
+    if (!d->ticker_hwnd)
+        WARN("failed to create ticker HWND, falling back to direct send\n");
+    else
+        TRACE(" ticker HWND=%p (owner=this thread)\n", d->ticker_hwnd);
+
+    for (;;)
+    {
+        struct dcomp_target *snap[16];
+        int n = 0, i;
+        DWORD w = WaitForSingleObject(d->tick_stop, 33);     /* ~30Hz */
+        if (w == WAIT_OBJECT_0) break;                       /* stop signaled */
+
+        /* Snapshot the target list under the device cs, but do NOT hold the
+         * cs while walking visuals + calling wayland_compose_export_visual (which can
+         * SendMessage). Holding cs across SendMessage produced deadlocks:
+         * CEF's main thread blocked here on the cs and never pumped messages,
+         * so SendMessage from the ticker never returned. */
+        EnterCriticalSection(&d->cs);
+        {
+            struct dcomp_target *t;
+            LIST_FOR_EACH_ENTRY(t, &d->targets, struct dcomp_target, entry)
+            {
+                if (n >= (int)(sizeof(snap)/sizeof(snap[0]))) break;
+                IDCompositionTarget_AddRef(&t->IDCompositionTarget_iface);
+                snap[n++] = t;
+            }
+        }
+        LeaveCriticalSection(&d->cs);
+
+        for (i = 0; i < n; i++)
+        {
+            struct dcomp_target *t = snap[i];
+            if (t->root) wayland_compose_walk_visual_quiet(t, t->root);
+            IDCompositionTarget_Release(&t->IDCompositionTarget_iface);
+        }
+    }
+    TRACE(" ticker exiting device=%p\n", d);
+    return 0;
+}
