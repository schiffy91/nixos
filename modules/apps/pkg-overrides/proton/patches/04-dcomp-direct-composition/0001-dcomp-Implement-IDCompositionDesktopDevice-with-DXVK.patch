+static HRESULT WINAPI surface_QueryInterface(IDCompositionSurface *iface, REFIID iid, void **out)
+{
+    if (IsEqualGUID(iid, &IID_IUnknown) || IsEqualGUID(iid, &IID_IDCompositionSurface))
+    { IDCompositionSurface_AddRef(iface); *out = iface; return S_OK; }
+    WARN("surface QI %s — not supported\n", debugstr_guid(iid));
+    *out = NULL;
+    return E_NOINTERFACE;
+}
+
+static ULONG WINAPI surface_AddRef(IDCompositionSurface *iface)
+{ struct dcomp_surface *s = impl_from_IDCompositionSurface(iface); return InterlockedIncrement(&s->ref); }
+
+static ULONG WINAPI surface_Release(IDCompositionSurface *iface)
+{
+    struct dcomp_surface *s = impl_from_IDCompositionSurface(iface);
+    ULONG r = InterlockedDecrement(&s->ref);
+    if (!r)
+    {
+        if (s->draw_texture) ID3D11Texture2D_Release(s->draw_texture);
+        list_remove(&s->entry);
+        free(s);
+    }
+    return r;
+}
+
+static HRESULT WINAPI surface_BeginDraw(IDCompositionSurface *iface, const RECT *rect,
+                                         REFIID iid, void **object, POINT *offset)
+{
+    struct dcomp_surface *s = impl_from_IDCompositionSurface(iface);
+    D3D11_TEXTURE2D_DESC desc = {0};
+    HRESULT hr;
+
+    TRACE("surface=%p rect=%p iid=%s\n", s, rect, debugstr_guid(iid));
+
+    if (!s->device || !s->device->d3d11_device)
+    {
+        FIXME("no D3D11 device available for BeginDraw\n");
+        *object = NULL;
+        return E_FAIL;
+    }
+    if (!IsEqualGUID(iid, &IID_ID3D11Texture2D))
+    {
+        FIXME("BeginDraw with non-D3D11 iid %s — not supported\n", debugstr_guid(iid));
+        *object = NULL;
+        return E_NOINTERFACE;
+    }
+    if (s->in_draw)
+    {
+        WARN("surface=%p already in BeginDraw\n", s);
+        return DCOMPOSITION_ERROR_SURFACE_BEING_RENDERED;
+    }
+
+    if (!s->draw_texture)
+    {
+        desc.Width = s->width;
+        desc.Height = s->height;
+        desc.MipLevels = 1;
+        desc.ArraySize = 1;
+        desc.Format = s->format ? s->format : DXGI_FORMAT_B8G8R8A8_UNORM;
+        desc.SampleDesc.Count = 1;
+        desc.Usage = D3D11_USAGE_DEFAULT;
+        desc.BindFlags = D3D11_BIND_RENDER_TARGET | D3D11_BIND_SHADER_RESOURCE;
+        desc.MiscFlags = D3D11_RESOURCE_MISC_SHARED;       /* enable dmabuf export via DXVK interop */
+        hr = ID3D11Device_CreateTexture2D(s->device->d3d11_device, &desc, NULL, &s->draw_texture);
+        if (FAILED(hr))
+        {
+            ERR("CreateTexture2D %ux%u failed hr=%#lx\n", s->width, s->height, hr);
+            *object = NULL;
+            return hr;
+        }
+    }
+
+    s->in_draw = TRUE;
+    ID3D11Texture2D_AddRef(s->draw_texture);
+    *object = s->draw_texture;
+    if (offset) { offset->x = 0; offset->y = 0; }
+    return S_OK;
+}
+
+static HRESULT WINAPI surface_EndDraw(IDCompositionSurface *iface)
+{
+    struct dcomp_surface *s = impl_from_IDCompositionSurface(iface);
+    TRACE("surface=%p\n", s);
+    s->in_draw = FALSE;
+    if (s->device) s->device->pending_commit = TRUE;
+    return S_OK;
+}
