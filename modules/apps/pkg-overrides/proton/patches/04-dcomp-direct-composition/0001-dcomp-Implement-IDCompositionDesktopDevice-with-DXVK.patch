+/* Find a DEVICE_LOCAL memory type from the requirements bitmask. */
+static int pick_memory_type(VkPhysicalDevice pdev, uint32_t bits, VkFlags want)
+{
+    VkPhysicalDeviceMemoryProperties mp = {0};
+    uint32_t i;
+    p_vkGetPhysicalDeviceMemoryProperties(pdev, &mp);
+    for (i = 0; i < mp.memoryTypeCount; i++)
+        if ((bits & (1u << i)) && (mp.memoryTypes[i].propertyFlags & want) == want)
+            return i;
+    /* fallback: first matching bit */
+    for (i = 0; i < mp.memoryTypeCount; i++) if (bits & (1u << i)) return i;
+    return -1;
+}
