+/* ─────── DXGI format → DRM fourcc + VkFormat lookup ─────── */
+static uint32_t dxgi_to_drm_fourcc(DXGI_FORMAT f, BOOL *opaque)
+{
+    if (opaque) *opaque = FALSE;
+    switch (f)
+    {
+    case DXGI_FORMAT_B8G8R8A8_UNORM:
+    case DXGI_FORMAT_B8G8R8A8_UNORM_SRGB:    return DRM_FORMAT_ARGB8888;
+    case DXGI_FORMAT_B8G8R8X8_UNORM:         if (opaque) *opaque = TRUE; return DRM_FORMAT_XRGB8888;
+    case DXGI_FORMAT_R8G8B8A8_UNORM:
+    case DXGI_FORMAT_R8G8B8A8_UNORM_SRGB:    return DRM_FORMAT_ABGR8888;
+    case DXGI_FORMAT_R10G10B10A2_UNORM:      return DRM_FORMAT_ABGR2101010;
+    case DXGI_FORMAT_R16G16B16A16_FLOAT:     return DRM_FORMAT_ABGR16161616F;
+    default:                                  return 0;
+    }
+}
