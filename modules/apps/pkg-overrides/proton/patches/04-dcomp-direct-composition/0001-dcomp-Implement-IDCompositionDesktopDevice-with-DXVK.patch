+#define LOADVK(name) do { p_##name = (void *)GetProcAddress(g_vulkan, #name); \
+    if (!p_##name) { ERR("missing %s\n", #name); g_vulkan = NULL; return FALSE; } } while (0)
+#define LOADVK_DEV(dev, name) do { p_##name = (void *)p_vkGetDeviceProcAddr(dev, #name); \
