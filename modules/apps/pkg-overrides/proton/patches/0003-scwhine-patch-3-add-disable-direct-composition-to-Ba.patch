From ea632c3cc358c9d2f2e2902f4bba5fdaf818b126 Mon Sep 17 00:00:00 2001
From: scwhine <scwhine@fractal-north>
Date: Mon, 18 May 2026 20:18:03 -0700
Subject: [PATCH 3/4] scwhine patch 3: add --disable-direct-composition to
 Battle.net CEF flags

dcomp.dll is a stub in wine; CEF tries DirectComposition by default, fails silently,
and never paints to the layered window. Disable DC to force fallback paint path.

diff --git a/dlls/kernelbase/process.c b/dlls/kernelbase/process.c
index 7f80bf59..dfebc12a 100644
--- a/dlls/kernelbase/process.c
+++ b/dlls/kernelbase/process.c
@@ -624,7 +624,7 @@ static const WCHAR *hack_append_command_line( const WCHAR *cmd )
     /* Generally just workarounds for winewayland not supporting cross process rendering (yet) */
     static const struct option wayland_options[] = {
         {L"launcher_epic.exe", L" --in-process-gpu"}, /* ZZZ EGS */
-        {L"Battle.net.exe", L" --in-process-gpu"},
+        {L"Battle.net.exe", L" --in-process-gpu --disable-direct-composition"},
         {L"RSI Launcher.exe", L" --in-process-gpu"},
         {L"EADesktop.exe", L" --in-process-gpu"},
         {L"Launcher.exe", L" --in-process-gpu", "230410"}, /* Warframe steam */
