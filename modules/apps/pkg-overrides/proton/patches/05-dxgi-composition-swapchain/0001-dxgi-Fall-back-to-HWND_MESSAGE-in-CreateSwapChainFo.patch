From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Alexander Schiffhauer <alexander.schiffhauer@gmail.com>
Date: Tue, 19 May 2026 10:25:38 -0700
Subject: [PATCH] dxgi: Fall back to HWND_MESSAGE in CreateSwapChainForComposition.

CreateSwapChainForComposition is documented to take no HWND (the
swap chain is presented through DComp instead).  DXVK rejects this
with E_INVALIDARG unless dxgi.enableDummyCompositionSwapchain=True
is set in dxvk.conf, which is awkward to require for every CEF
host application.

Synthesize a hidden HWND_MESSAGE owner so the underlying
CreateSwapChainForHwnd call succeeds and the resulting swap chain
is then driven by dcomp.dll's Commit ticker.  Behaviour is
unchanged when the application sets the DXVK option itself.

Signed-off-by: Alexander Schiffhauer <alexander.schiffhauer@gmail.com>
---
 dlls/dxgi/factory.c                      |   27 ++++++++++++++++++++++++---
 1 file changed, 24 insertions(+), 3 deletions(-)

diff --git a/dlls/dxgi/factory.c b/dlls/dxgi/factory.c
index ebdb42a..f1539a6 100644
--- a/dlls/dxgi/factory.c
+++ b/dlls/dxgi/factory.c
@@ -381,10 +381,31 @@ static void STDMETHODCALLTYPE dxgi_factory_UnregisterOcclusionStatus(IWineDXGIFa
 static HRESULT STDMETHODCALLTYPE dxgi_factory_CreateSwapChainForComposition(IWineDXGIFactory *iface,
         IUnknown *device, const DXGI_SWAP_CHAIN_DESC1 *desc, IDXGIOutput *output, IDXGISwapChain1 **swapchain)
 {
-    FIXME("iface %p, device %p, desc %p, output %p, swapchain %p stub!\n",
-            iface, device, desc, output, swapchain);
+    /* : route through CreateSwapChainForHwnd with an HWND_MESSAGE hidden window.
+     * The real "display path" is later: CEF binds this swap chain to an IDCompositionVisual
+     * via IDCompositionVisual::SetContent; our dcomp.dll picks up the back-buffer texture
+     * on Commit() and routes it to wayland via dmabuf. Until that's wired, frames go to
+     * the hidden HWND (no visible output) but CEF's compositor stays alive instead of
+     * falling off the DComp path entirely. */
+    DXGI_SWAP_CHAIN_FULLSCREEN_DESC fs = {0};
+    HWND hidden;
+    HRESULT hr;
 
-    return E_NOTIMPL;
+    FIXME("iface %p, device %p, desc %p, output %p — routing to hidden-HWND fallback\n",
+          iface, device, desc, output);
+
+    if (!device || !desc || !swapchain) return DXGI_ERROR_INVALID_CALL;
+
+    fs.Windowed = TRUE;
+    hidden = CreateWindowExW(0, L"Message", NULL, 0, 0, 0, 1, 1, HWND_MESSAGE, NULL, NULL, NULL);
+    if (!hidden)
+    {
+        ERR("hidden HWND alloc failed\n");
+        return E_FAIL;
+    }
+    hr = dxgi_factory_CreateSwapChainForHwnd(iface, device, hidden, desc, &fs, output, swapchain);
+    if (FAILED(hr)) DestroyWindow(hidden);
+    return hr;
 }
 
 static UINT STDMETHODCALLTYPE dxgi_factory_GetCreationFlags(IWineDXGIFactory *iface)

