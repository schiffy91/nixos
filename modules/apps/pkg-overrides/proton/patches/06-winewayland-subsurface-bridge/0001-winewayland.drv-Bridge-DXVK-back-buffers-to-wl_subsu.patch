diff --git a/dlls/winewayland.drv/waylanddrv.h b/dlls/winewayland.drv/waylanddrv.h
index 9ae568b..2a7917c 100644
--- a/dlls/winewayland.drv/waylanddrv.h
+++ b/dlls/winewayland.drv/waylanddrv.h
@@ -82,6 +82,36 @@ enum wayland_window_message
     WM_WAYLAND_INIT_DISPLAY_DEVICES = WM_WINE_FIRST_DRIVER_MSG,
     WM_WAYLAND_CONFIGURE,
     WM_WAYLAND_SET_FOREGROUND,
+    WM_WAYLAND_COMPOSE_ATTACH,   /* lParam = struct wayland_compose_attach_request* */
+};
+
+/* Shared bridge struct: dcomp.dll fills this and SendMessageW's it to a HWND.
+ * winewayland.drv's WAYLAND_WindowMessage handler does the Vulkan export work
+ * using native libvulkan.so (NOT wine's vulkan-1.dll, which can't operate on
+ * DXVK-tracked devices). All Vulkan handles are stored as uint64 so the struct
+ * layout matches across the PE/Unix boundary (PE i386: pointers are 32-bit,
+ * Unix x86_64: pointers are 64-bit; zero-extension is correct since wine PE
+ * addresses occupy the low 32 bits of 64-bit space). */
+struct wayland_compose_attach_request
+{
+    /* DXVK's source VkImage + dims + Vulkan format + current layout */
+    uint64_t  src_image;            /* VkImage (non-dispatchable, 64-bit) */
+    uint32_t  src_layout;           /* VkImageLayout (enum/int) */
+    uint32_t  vk_format;            /* VkFormat from GetVulkanImageInfo */
+    uint32_t  width, height;
+    /* DXVK handles (dispatchable, but stored uint64 for PE↔Unix layout match) */
+    uint64_t  vk_instance;
+    uint64_t  vk_physical_device;
+    uint64_t  vk_device;
+    uint64_t  vk_queue;
+    uint32_t  queue_family;
+    uint32_t  _pad;                 /* explicit pad for 8-byte alignment of following uint64 */
+    /* HWND of the DComp target — the actual BNet window this frame belongs
+     * to. We send the WM_WAYLAND_COMPOSE_ATTACH message to a hidden
+     * HWND owned by the dcomp ticker thread (so the wndproc dispatches
+     * inline on the ticker, off BNet's UI thread), and carry the real
+     * destination HWND in the request itself. */
+    void     *target_hwnd;
 };
 
 enum wayland_surface_config_state
@@ -356,6 +386,19 @@ struct wayland_shm_buffer
     HRGN damage_region;
 };
 
+/* : GPU dmabuf buffer for cross-process hardware-accelerated paths */
+struct wayland_dmabuf_buffer
+{
+    struct wl_buffer *wl_buffer;
+    int fd;                 /* owned; dup'd from caller */
+    int width, height;
+    uint32_t drm_format;    /* fourcc, e.g. DRM_FORMAT_ARGB8888 */
+    uint64_t modifier;
+    uint32_t stride;
+    uint32_t offset;
+    LONG ref;
+};
+
 struct wayland_surface
 {
     HWND hwnd;
@@ -456,6 +499,20 @@ struct wayland_shm_buffer *wayland_shm_buffer_from_color_bitmaps(HDC hdc, HBITMA
 void wayland_shm_buffer_ref(struct wayland_shm_buffer *shm_buffer);
 void wayland_shm_buffer_unref(struct wayland_shm_buffer *shm_buffer);
 
+/**********************************************************************
+ *          Wayland dmabuf buffer
+ */
+
+struct wayland_dmabuf_buffer *wayland_dmabuf_buffer_create(int fd, int width, int height,
+                                                           uint32_t drm_format, uint64_t modifier,
+                                                           uint32_t stride, uint32_t offset);
+void wayland_dmabuf_buffer_ref(struct wayland_dmabuf_buffer *buf);
+void wayland_dmabuf_buffer_unref(struct wayland_dmabuf_buffer *buf);
+void wayland_surface_attach_dmabuf(struct wayland_surface *surface,
+                                   struct wayland_dmabuf_buffer *buf,
+                                   HRGN surface_damage_region);
+void wayland_compose_handle_attach(HWND hwnd, const struct wayland_compose_attach_request *req);
+
 /**********************************************************************
  *          Wayland Window
  */
