+/**********************************************************************
+ *          wayland_dmabuf_buffer_create 
+ *
+ * Wraps a caller-provided GPU dmabuf FD as a wl_buffer via the
+ * zwp_linux_dmabuf_v1 protocol. Takes ownership of the fd (via dup).
+ */
+struct wayland_dmabuf_buffer *wayland_dmabuf_buffer_create(int fd, int width, int height,
+                                                           uint32_t drm_format, uint64_t modifier,
+                                                           uint32_t stride, uint32_t offset)
+{
+    struct wayland_dmabuf_buffer *buf;
+    struct zwp_linux_buffer_params_v1 *params;
+
+    if (!process_wayland.zwp_linux_dmabuf_v1)
+    {
+        ERR("zwp_linux_dmabuf_v1 not bound; cannot create dmabuf buffer\n");
+        return NULL;
+    }
+    if (fd < 0 || width <= 0 || height <= 0 || stride == 0)
+    {
+        ERR("invalid args fd=%d w=%d h=%d stride=%u\n", fd, width, height, stride);
+        return NULL;
+    }
+
+    buf = calloc(1, sizeof(*buf));
+    if (!buf) return NULL;
+
+    buf->fd = dup(fd);
+    if (buf->fd < 0) { free(buf); return NULL; }
+    buf->width      = width;
+    buf->height     = height;
+    buf->drm_format = drm_format;
+    buf->modifier   = modifier;
+    buf->stride     = stride;
+    buf->offset     = offset;
+    buf->ref        = 1;
+
+    params = zwp_linux_dmabuf_v1_create_params(process_wayland.zwp_linux_dmabuf_v1);
+    if (!params)
+    {
+        close(buf->fd); free(buf);
+        return NULL;
+    }
+    zwp_linux_buffer_params_v1_add(params, buf->fd, 0 /*plane*/, offset, stride,
+                                   (uint32_t)(modifier >> 32),
+                                   (uint32_t)(modifier & 0xffffffffu));
+    buf->wl_buffer = zwp_linux_buffer_params_v1_create_immed(params, width, height, drm_format, 0);
+    zwp_linux_buffer_params_v1_destroy(params);
+
+    if (!buf->wl_buffer)
+    {
+        ERR("create_immed failed (fmt=0x%08x mod=0x%llx %dx%d)\n",
+            drm_format, (unsigned long long)modifier, width, height);
+        close(buf->fd); free(buf);
+        return NULL;
+    }
+
+    TRACE("dmabuf buf=%p wl_buffer=%p (%dx%d fmt=0x%08x mod=0x%llx stride=%u)\n",
+          buf, buf->wl_buffer, width, height, drm_format,
+          (unsigned long long)modifier, stride);
+    return buf;
+}
+
+void wayland_dmabuf_buffer_ref(struct wayland_dmabuf_buffer *buf)
+{
+    InterlockedIncrement(&buf->ref);
+}
+
+void wayland_dmabuf_buffer_unref(struct wayland_dmabuf_buffer *buf)
+{
+    if (InterlockedDecrement(&buf->ref) > 0) return;
+    if (buf->wl_buffer) wl_buffer_destroy(buf->wl_buffer);
+    if (buf->fd >= 0) close(buf->fd);
+    free(buf);
+}
+
+/**********************************************************************
+ *          wayland_surface_attach_dmabuf 
+ *
+ * Attaches a GPU dmabuf-backed wl_buffer to the surface. Bypasses any
+ * CPU bitmap path. The caller retains ownership of the dmabuf wrapper;
+ * we take an extra ref so the buffer survives until the compositor
+ * releases it.
+ */
+void wayland_surface_attach_dmabuf(struct wayland_surface *surface,
+                                   struct wayland_dmabuf_buffer *buf,
+                                   HRGN surface_damage_region)
+{
+    RGNDATA *surface_damage;
+    int win_width, win_height;
+
+    WARN(" ATTACH surface=%p dmabuf=%p (%dx%d) window.rect=%d,%d-%d,%d\n",
+         surface, buf, buf->width, buf->height,
+         (int)surface->window.rect.left, (int)surface->window.rect.top,
+         (int)surface->window.rect.right, (int)surface->window.rect.bottom);
+
+    wayland_dmabuf_buffer_ref(buf);
+
+    wl_surface_attach(surface->wl_surface, buf->wl_buffer, 0, 0);
+
+    surface_damage = get_region_data(surface_damage_region);
+    if (surface_damage)
+    {
+        RECT *r     = (RECT *)surface_damage->Buffer;
+        RECT *r_end = r + surface_damage->rdh.nCount;
+        for (; r < r_end; r++)
+        {
+            wl_surface_damage_buffer(surface->wl_surface,
+                                     r->left, r->top,
+                                     r->right - r->left,
+                                     r->bottom - r->top);
+        }
+        free(surface_damage);
+    }
+    else
+    {
+        wl_surface_damage_buffer(surface->wl_surface, 0, 0, buf->width, buf->height);
+    }
+
+    /* Source = full buffer. Destination = the wine HWND rect (the size we want
+     * the surface to occupy on screen, in wayland surface-logical units). The
+     * previous code cropped source to min(window, buffer) which black-padded
+     * the surface whenever the buffer pixel size exceeded the window logical
+     * size. Setting destination explicitly here also avoids relying on a prior
+     * wayland_surface_reconfigure_size having been called for *this* surface
+     * — CEF's overlay subsurfaces in particular never get one. */
+    wp_viewport_set_source(surface->wp_viewport, 0, 0,
+                           wl_fixed_from_int(buf->width),
+                           wl_fixed_from_int(buf->height));
+
+    win_width  = surface->window.rect.right  - surface->window.rect.left;
+    win_height = surface->window.rect.bottom - surface->window.rect.top;
+    if (win_width  <= 0) win_width  = buf->width;
+    if (win_height <= 0) win_height = buf->height;
+    wp_viewport_set_destination(surface->wp_viewport, win_width, win_height);
+
+    surface->content_width  = win_width;
+    surface->content_height = win_height;
+}
+
