index 45eeed9..2ca466a 100644
--- a/dlls/winewayland.drv/wayland_pointer.c
+++ b/dlls/winewayland.drv/wayland_pointer.c
@@ -1006,7 +1006,30 @@ static void wayland_set_cursor(HWND hwnd, HCURSOR hcursor, BOOL use_hcursor)
     pthread_mutex_lock(&pointer->mutex);
     if (pointer->focused_hwnd == hwnd)
     {
-        if ((!use_hcursor && pointer->wp_cursor_shape_device_v1) ||
+        /* If the app hasn't set a cursor on this window (e.g. CEF-driven UIs
+         * like Battle.net), fall back to the compositor's default arrow via
+         * wp_cursor_shape_v1 so the pointer stays visible. Without this, the
+         * later else branch sets an empty cursor surface and the cursor
+         * disappears as soon as it enters the window. Lazily create the
+         * cursor-shape device since the app may never trigger SetCursor. */
+        if (use_hcursor && !hcursor && process_wayland.wp_cursor_shape_manager_v1)
+        {
+            if (!pointer->wp_cursor_shape_device_v1)
+                pointer->wp_cursor_shape_device_v1 =
+                    wp_cursor_shape_manager_v1_get_pointer(
+                        process_wayland.wp_cursor_shape_manager_v1,
+                        pointer->wl_pointer);
+            if (pointer->wp_cursor_shape_device_v1)
+            {
+                TRACE("default cursor shape for hwnd=%p (no app cursor)\n", hwnd);
+                wp_cursor_shape_device_v1_set_shape(
+                    pointer->wp_cursor_shape_device_v1,
+                    pointer->enter_serial,
+                    WP_CURSOR_SHAPE_DEVICE_V1_SHAPE_DEFAULT);
+                wayland_pointer_clear_cursor_surface();
+            }
+        }
+        else if ((!use_hcursor && pointer->wp_cursor_shape_device_v1) ||
             (use_hcursor && hcursor && wayland_pointer_set_cursor_shape(hcursor)))
         {
             wayland_pointer_clear_cursor_surface();
diff --git a/dlls/winewayland.drv/wayland_compose.c b/dlls/winewayland.drv/wayland_compose.c
new file mode 100644
index 0000000..e7ad9aa
--- /dev/null
+++ b/dlls/winewayland.drv/wayland_compose.c
@@ -0,0 +1,427 @@
+/*
+ * : Unix-side Vulkan→wl_shm bridge for DComp HW-accel.
+ *
+ * dcomp.dll PE-side hands us DXVK's PE-side Vulkan handles via the
+ * WM_WAYLAND_COMPOSE_ATTACH window message. We convert those PE
+ * handles to wine-internal vulkan_device/vulkan_queue structs (via the
+ * inline accessors in include/wine/vulkan_driver.h), giving us both the
+ * native VkDevice handle AND the wine-resolved entry-point function
+ * pointers — no second libvulkan loader needed.
+ *
+ * The pipeline:
+ *   - Allocate a HOST_VISIBLE | HOST_COHERENT VkBuffer big enough to hold one
+ *     readback of CEF's DComp swap-chain back buffer.
+ *   - vkCmdCopyImageToBuffer to copy CEF's GPU image into that buffer.
+ *   - vkMapMemory + memcpy into a wayland wl_shm buffer (row-by-row, since the
+ *     Vulkan buffer can have arbitrary row padding).
+ *   - Attach the shm buffer to a wl_subsurface of the toplevel ancestor's
+ *     wl_surface so we composite ON TOP of wine's CPU bitmap instead of
+ *     replacing it.
+ *
+ * The SHM path is slower than a zero-copy dmabuf export (one full readback per
+ * frame), but works with ANY GPU/driver/compositor combo — no NVIDIA dmabuf
+ * import compatibility issues, no DRM modifier negotiation, no cross-GPU FDs.
+ */
+
+#if 0
+#pragma makedep unix
+#endif
+
+#include "config.h"
+
+#include <assert.h>
+#include <limits.h>
+#include <pthread.h>
+#include <stdlib.h>
+#include <string.h>
+#include <unistd.h>
+
+#define WINE_UNIX_LIB
+#include "waylanddrv.h"
+#include "wine/debug.h"
+#include "wine/vulkan.h"
+#include "wine/vulkan_driver.h"
+
+WINE_DEFAULT_DEBUG_CHANNEL(waylanddrv);
+
+struct wayland_compose_target
+{
+    struct wl_list  link;
+    HWND            hwnd;
+    struct vulkan_device *vk_device;
+    struct vulkan_queue  *vk_queue;
+    uint32_t        queue_family;
+    VkCommandPool   cmd_pool;
+    VkCommandBuffer cmd_buf;
+    VkFence         fence;
+    VkBuffer        dst_buffer;
+    VkDeviceMemory  dst_memory;
+    VkDeviceSize    buffer_size;
+    void           *mapped;
+    uint32_t        width, height;
+    VkFormat        format;
+    struct wayland_shm_buffer *shm_buffer;
+    BOOL            valid;
+    struct wl_surface       *sub_wl_surface;
+    struct wl_subsurface    *sub_wl_subsurface;
+    struct wp_viewport      *sub_wp_viewport;
+    HWND                     sub_parent_hwnd;
+    int                      sub_x, sub_y;
+};
+
+static struct wl_list   g_targets = { &g_targets, &g_targets };
+static pthread_mutex_t  g_targets_mutex = PTHREAD_MUTEX_INITIALIZER;
+
+static struct wayland_compose_target *wayland_compose_target_get(HWND hwnd)
+{
+    struct wayland_compose_target *t;
+    pthread_mutex_lock(&g_targets_mutex);
+    wl_list_for_each(t, &g_targets, link)
+        if (t->hwnd == hwnd) { pthread_mutex_unlock(&g_targets_mutex); return t; }
+    t = calloc(1, sizeof(*t));
+    if (t) { t->hwnd = hwnd; wl_list_insert(&g_targets, &t->link); }
+    pthread_mutex_unlock(&g_targets_mutex);
+    return t;
+}
+
+static int pick_host_visible_memory(struct vulkan_device *dev, uint32_t bits)
+{
+    VkPhysicalDeviceMemoryProperties mp;
+    uint32_t i;
+    const VkMemoryPropertyFlags want = VK_MEMORY_PROPERTY_HOST_VISIBLE_BIT |
+                                       VK_MEMORY_PROPERTY_HOST_COHERENT_BIT;
+    dev->physical_device->instance->p_vkGetPhysicalDeviceMemoryProperties(
+        dev->physical_device->host.physical_device, &mp);
+    for (i = 0; i < mp.memoryTypeCount; i++)
+        if ((bits & (1u << i)) && (mp.memoryTypes[i].propertyFlags & want) == want)
+            return (int)i;
+    for (i = 0; i < mp.memoryTypeCount; i++)
+        if ((bits & (1u << i)) && (mp.memoryTypes[i].propertyFlags & VK_MEMORY_PROPERTY_HOST_VISIBLE_BIT))
+            return (int)i;
+    return -1;
+}
+
+static enum wl_shm_format vk_to_wl_shm(VkFormat f)
+{
+    switch (f)
+    {
+    case VK_FORMAT_B8G8R8A8_UNORM:
+    case VK_FORMAT_B8G8R8A8_SRGB:           return WL_SHM_FORMAT_ARGB8888;
+    case VK_FORMAT_R8G8B8A8_UNORM:
+    case VK_FORMAT_R8G8B8A8_SRGB:           return WL_SHM_FORMAT_ABGR8888;
+    default:                                return WL_SHM_FORMAT_ARGB8888;
+    }
+}
+
+static BOOL wayland_compose_target_ensure(struct wayland_compose_target *t, struct vulkan_device *dev,
+                                  struct vulkan_queue *queue, uint32_t qfam,
+                                  uint32_t w, uint32_t h, VkFormat fmt)
+{
+    VkDevice host_dev = dev->host.device;
+
+    if (t->valid && t->vk_device == dev && t->width == w && t->height == h && t->format == fmt)
+        return TRUE;
+    if (t->valid)
+    {
+        if (t->mapped) { dev->p_vkUnmapMemory(host_dev, t->dst_memory); t->mapped = NULL; }
+        if (t->dst_buffer) dev->p_vkDestroyBuffer(host_dev, t->dst_buffer, NULL);
+        if (t->dst_memory) dev->p_vkFreeMemory(host_dev, t->dst_memory, NULL);
+        if (t->shm_buffer) { wayland_shm_buffer_unref(t->shm_buffer); t->shm_buffer = NULL; }
+        t->dst_buffer = VK_NULL_HANDLE; t->dst_memory = VK_NULL_HANDLE;
+        t->valid = FALSE;
+    }
+    if (!t->cmd_pool)
+    {
+        VkCommandPoolCreateInfo cpi = { VK_STRUCTURE_TYPE_COMMAND_POOL_CREATE_INFO };
+        VkCommandBufferAllocateInfo cba = { VK_STRUCTURE_TYPE_COMMAND_BUFFER_ALLOCATE_INFO };
+        VkFenceCreateInfo fci = { VK_STRUCTURE_TYPE_FENCE_CREATE_INFO };
+        cpi.flags = VK_COMMAND_POOL_CREATE_RESET_COMMAND_BUFFER_BIT;
+        cpi.queueFamilyIndex = qfam;
+        if (dev->p_vkCreateCommandPool(host_dev, &cpi, NULL, &t->cmd_pool) != VK_SUCCESS)
+        { ERR("vkCreateCommandPool failed\n"); return FALSE; }
+        cba.commandPool = t->cmd_pool;
+        cba.level = VK_COMMAND_BUFFER_LEVEL_PRIMARY;
+        cba.commandBufferCount = 1;
+        if (dev->p_vkAllocateCommandBuffers(host_dev, &cba, &t->cmd_buf) != VK_SUCCESS)
+        { ERR("vkAllocateCommandBuffers failed\n"); return FALSE; }
+        if (dev->p_vkCreateFence(host_dev, &fci, NULL, &t->fence) != VK_SUCCESS)
+        { ERR("vkCreateFence failed\n"); return FALSE; }
+    }
+    /* Tightly-packed BGRA readback buffer; matches wl_shm row layout. */
+    t->buffer_size = (VkDeviceSize)w * h * 4;
+    {
+        VkBufferCreateInfo bci = { VK_STRUCTURE_TYPE_BUFFER_CREATE_INFO };
+        bci.size = t->buffer_size;
+        bci.usage = VK_BUFFER_USAGE_TRANSFER_DST_BIT;
+        bci.sharingMode = VK_SHARING_MODE_EXCLUSIVE;
+        if (dev->p_vkCreateBuffer(host_dev, &bci, NULL, &t->dst_buffer) != VK_SUCCESS)
+        { ERR("vkCreateBuffer failed\n"); return FALSE; }
+    }
+    {
+        VkMemoryRequirements mreq;
+        VkMemoryAllocateInfo ai = { VK_STRUCTURE_TYPE_MEMORY_ALLOCATE_INFO };
+        int mt;
+        dev->p_vkGetBufferMemoryRequirements(host_dev, t->dst_buffer, &mreq);
+        mt = pick_host_visible_memory(dev, mreq.memoryTypeBits);
+        if (mt < 0) { ERR("no host-visible mem type\n"); return FALSE; }
+        ai.allocationSize = mreq.size;
+        ai.memoryTypeIndex = (uint32_t)mt;
+        if (dev->p_vkAllocateMemory(host_dev, &ai, NULL, &t->dst_memory) != VK_SUCCESS)
+        { ERR("vkAllocateMemory host-visible failed\n"); return FALSE; }
+        if (dev->p_vkBindBufferMemory(host_dev, t->dst_buffer, t->dst_memory, 0) != VK_SUCCESS)
+        { ERR("vkBindBufferMemory failed\n"); return FALSE; }
+        if (dev->p_vkMapMemory(host_dev, t->dst_memory, 0, VK_WHOLE_SIZE, 0, &t->mapped) != VK_SUCCESS)
+        { ERR("vkMapMemory failed\n"); return FALSE; }
+    }
+    t->shm_buffer = wayland_shm_buffer_create((int)w, (int)h, vk_to_wl_shm(fmt));
+    if (!t->shm_buffer) { ERR("wayland_shm_buffer_create failed (%ux%u)\n", w, h); return FALSE; }
+    t->vk_device = dev; t->vk_queue = queue; t->queue_family = qfam;
+    t->width = w; t->height = h; t->format = fmt;
+    t->valid = TRUE;
+    TRACE(" target=%p built: buf=0x%llx mem=0x%llx mapped=%p shm=%p %ux%u fmt=%d\n",
+          t, (unsigned long long)t->dst_buffer, (unsigned long long)t->dst_memory,
+          t->mapped, t->shm_buffer, w, h, fmt);
+    return TRUE;
+}
+
+void wayland_compose_handle_attach(HWND hwnd, const struct wayland_compose_attach_request *req)
+{
+    struct wayland_compose_target *t;
+    struct vulkan_device *dev;
+    struct vulkan_queue *queue;
+    VkDevice host_dev;
+    VkQueue  host_queue;
+    VkImage  src_img = (VkImage)req->src_image;
+    VkImageLayout src_layout = (VkImageLayout)req->src_layout;
+    VkFormat fmt = (VkFormat)req->vk_format;
+    struct wayland_win_data *data;
+    struct wayland_surface *surface;
+    /* The message's hwnd is the dcomp ticker's hidden HWND (so the wndproc
+     * dispatches inline on the ticker thread). The actual DComp target HWND
+     * — what we use to look up the wayland_surface tree — comes from the
+     * request itself. Fall back to the message's hwnd for older request
+     * layouts that didn't carry target_hwnd. */
+    HWND target_hwnd = req->target_hwnd ? (HWND)req->target_hwnd : hwnd;
+
+    if (!req->vk_device || !req->vk_queue) { ERR("NULL device/queue\n"); return; }
+    dev   = vulkan_device_from_handle((VkDevice)(uintptr_t)req->vk_device);
+    queue = vulkan_queue_from_handle((VkQueue)(uintptr_t)req->vk_queue);
+    if (!dev || !queue) { ERR("handle conversion failed dev=%p queue=%p\n", dev, queue); return; }
+    host_dev   = dev->host.device;
+    host_queue = queue->host.queue;
+
+    TRACE(" attach target_hwnd=%p src_image=0x%llx %ux%u fmt=%d layout=%d qfam=%u\n",
+          target_hwnd, (unsigned long long)req->src_image, req->width, req->height,
+          fmt, src_layout, req->queue_family);
+
+    hwnd = target_hwnd;     /* rest of function operates on the real target */
+    t = wayland_compose_target_get(hwnd);
+    if (!t) return;
+    if (!wayland_compose_target_ensure(t, dev, queue, req->queue_family, req->width, req->height, fmt))
+        return;
+
+    /* Record command buffer: barrier src to TRANSFER_SRC, copy image to buffer,
+     * barrier src back to its prior layout. */
+    dev->p_vkResetCommandBuffer(t->cmd_buf, 0);
+    {
+        VkCommandBufferBeginInfo cbb = { VK_STRUCTURE_TYPE_COMMAND_BUFFER_BEGIN_INFO };
+        cbb.flags = VK_COMMAND_BUFFER_USAGE_ONE_TIME_SUBMIT_BIT;
+        dev->p_vkBeginCommandBuffer(t->cmd_buf, &cbb);
+    }
+    {
+        VkImageMemoryBarrier b = {0};
+        b.sType = VK_STRUCTURE_TYPE_IMAGE_MEMORY_BARRIER;
+        b.srcAccessMask = VK_ACCESS_MEMORY_WRITE_BIT;
+        b.dstAccessMask = VK_ACCESS_TRANSFER_READ_BIT;
+        b.oldLayout = src_layout;
+        b.newLayout = VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL;
+        b.srcQueueFamilyIndex = VK_QUEUE_FAMILY_IGNORED;
+        b.dstQueueFamilyIndex = VK_QUEUE_FAMILY_IGNORED;
+        b.image = src_img;
+        b.subresourceRange.aspectMask = VK_IMAGE_ASPECT_COLOR_BIT;
+        b.subresourceRange.levelCount = 1;
+        b.subresourceRange.layerCount = 1;
+        dev->p_vkCmdPipelineBarrier(t->cmd_buf,
+            VK_PIPELINE_STAGE_ALL_COMMANDS_BIT, VK_PIPELINE_STAGE_TRANSFER_BIT,
+            0, 0, NULL, 0, NULL, 1, &b);
+    }
+    {
+        VkBufferImageCopy region = {0};
+        region.bufferRowLength = req->width;   /* tightly packed */
+        region.bufferImageHeight = req->height;
+        region.imageSubresource.aspectMask = VK_IMAGE_ASPECT_COLOR_BIT;
+        region.imageSubresource.layerCount = 1;
+        region.imageExtent.width = req->width;
+        region.imageExtent.height = req->height;
+        region.imageExtent.depth = 1;
+        dev->p_vkCmdCopyImageToBuffer(t->cmd_buf, src_img, VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL,
+                                      t->dst_buffer, 1, &region);
+    }
+    {
+        VkImageMemoryBarrier b = {0};
+        b.sType = VK_STRUCTURE_TYPE_IMAGE_MEMORY_BARRIER;
+        b.srcAccessMask = VK_ACCESS_TRANSFER_READ_BIT;
+        b.dstAccessMask = VK_ACCESS_MEMORY_READ_BIT | VK_ACCESS_MEMORY_WRITE_BIT;
+        b.oldLayout = VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL;
+        b.newLayout = src_layout;
+        b.srcQueueFamilyIndex = VK_QUEUE_FAMILY_IGNORED;
+        b.dstQueueFamilyIndex = VK_QUEUE_FAMILY_IGNORED;
+        b.image = src_img;
+        b.subresourceRange.aspectMask = VK_IMAGE_ASPECT_COLOR_BIT;
+        b.subresourceRange.levelCount = 1;
+        b.subresourceRange.layerCount = 1;
+        dev->p_vkCmdPipelineBarrier(t->cmd_buf,
+            VK_PIPELINE_STAGE_TRANSFER_BIT, VK_PIPELINE_STAGE_ALL_COMMANDS_BIT,
+            0, 0, NULL, 0, NULL, 1, &b);
+    }
+    /* Make the host-visible buffer write available to the CPU. */
+    {
+        VkMemoryBarrier mb = { VK_STRUCTURE_TYPE_MEMORY_BARRIER };
+        mb.srcAccessMask = VK_ACCESS_TRANSFER_WRITE_BIT;
+        mb.dstAccessMask = VK_ACCESS_HOST_READ_BIT;
+        dev->p_vkCmdPipelineBarrier(t->cmd_buf,
+            VK_PIPELINE_STAGE_TRANSFER_BIT, VK_PIPELINE_STAGE_HOST_BIT,
+            0, 1, &mb, 0, NULL, 0, NULL);
+    }
+    dev->p_vkEndCommandBuffer(t->cmd_buf);
+
+    /* If a previous submit is still in flight, wait briefly. With the ticker
+     * pumping ~15Hz on the HWND owner thread, holding here for a full second
+     * blocks CEF's input message pump and clicks stop working. Cap the wait
+     * at 5ms — if the GPU is slower than that we'll get a slightly stale
+     * frame on screen, which is acceptable for a launcher UI. */
+    dev->p_vkWaitForFences(host_dev, 1, &t->fence, VK_TRUE, 5000000ull /* 5 ms */);
+    dev->p_vkResetFences(host_dev, 1, &t->fence);
+    {
+        VkSubmitInfo si = { VK_STRUCTURE_TYPE_SUBMIT_INFO };
+        si.commandBufferCount = 1;
+        si.pCommandBuffers = &t->cmd_buf;
+        if (dev->p_vkQueueSubmit(host_queue, 1, &si, t->fence) != VK_SUCCESS)
+        { ERR("vkQueueSubmit failed\n"); return; }
+    }
+    /* Brief wait for THIS submission to finish so the memcpy below sees the
+     * GPU-written pixels. Capped at 5ms to keep the message pump responsive;
+     * if the GPU is still busy we display the previous frame's contents. */
+    dev->p_vkWaitForFences(host_dev, 1, &t->fence, VK_TRUE, 5000000ull /* 5 ms */);
+
+    /* Copy from mapped Vulkan memory into the shm buffer. Both are tightly
+     * packed BGRA at the same width/height, so a single memcpy works. */
+    if (t->mapped && t->shm_buffer && t->shm_buffer->map_data)
+        memcpy(t->shm_buffer->map_data, t->mapped, t->buffer_size);
+
+    /* Path A: this HWND has its own wayland_surface (rare for CEF DComp targets
+     * but normal for visible toplevels) — attach directly. */
+    if ((data = wayland_win_data_get(hwnd)) && (surface = data->wayland_surface))
+    {
+        wl_surface_attach(surface->wl_surface, t->shm_buffer->wl_buffer, 0, 0);
+        wl_surface_damage_buffer(surface->wl_surface, 0, 0, t->width, t->height);
+        wl_surface_commit(surface->wl_surface);
+        wl_display_flush(process_wayland.wl_display);
+        wayland_win_data_release(data);
+        TRACE("attached shm to own surface hwnd=%p\n", hwnd);
+        return;
+    }
+    if (data) wayland_win_data_release(data);
+
+    /* Path B: walk up to the toplevel ancestor and composite via wl_subsurface
+     * on its wl_surface so wine's CPU bitmap stays visible underneath. */
+    {
+        HWND parent = hwnd;
+        struct wayland_win_data *pdata = NULL;
+        struct wayland_surface  *psurface = NULL;
+        int hops;
+
+        for (hops = 0; hops < 8; hops++)
+        {
+            HWND next = NtUserGetAncestor(parent, GA_ROOT);
+            if (!next) next = NtUserGetWindowRelative(parent, GW_OWNER);
+            if (!next || next == parent) break;
+            parent = next;
+            if ((pdata = wayland_win_data_get(parent)))
+            {
+                if (pdata->wayland_surface) { psurface = pdata->wayland_surface; break; }
+                wayland_win_data_release(pdata); pdata = NULL;
+            }
+        }
+        if (!psurface)
+        {
+            WARN("no wayland_surface for hwnd=%p or any ancestor\n", hwnd);
+            if (pdata) wayland_win_data_release(pdata);
+            return;
+        }
+
+        /* Lazily create our subsurface attached to the toplevel's wl_surface. */
+        if (!t->sub_wl_surface || t->sub_parent_hwnd != parent)
+        {
+            if (t->sub_wp_viewport)   { wp_viewport_destroy(t->sub_wp_viewport); t->sub_wp_viewport = NULL; }
+            if (t->sub_wl_subsurface) { wl_subsurface_destroy(t->sub_wl_subsurface); t->sub_wl_subsurface = NULL; }
+            if (t->sub_wl_surface)    { wl_surface_destroy(t->sub_wl_surface); t->sub_wl_surface = NULL; }
+
+            t->sub_wl_surface = wl_compositor_create_surface(process_wayland.wl_compositor);
+            if (!t->sub_wl_surface) { ERR("wl_compositor_create_surface failed\n"); goto sub_done; }
+            t->sub_wl_subsurface = wl_subcompositor_get_subsurface(process_wayland.wl_subcompositor,
+                                                                   t->sub_wl_surface,
+                                                                   psurface->wl_surface);
+            if (!t->sub_wl_subsurface) { ERR("get_subsurface failed\n"); goto sub_done; }
+            wl_subsurface_set_desync(t->sub_wl_subsurface);
+            /* Subsurfaces default to "input region = entire buffer", which
+             * makes the compositor route pointer/click events to the
+             * subsurface — but our wl_surface has no user_data, so wine maps
+             * the events to hwnd=NULL and they go nowhere. Set an empty input
+             * region so pointer events fall through to the parent toplevel
+             * (BNet's actual HWND). */
+            {
+                struct wl_region *empty = wl_compositor_create_region(process_wayland.wl_compositor);
+                if (empty)
+                {
+                    wl_surface_set_input_region(t->sub_wl_surface, empty);
+                    wl_region_destroy(empty);
+                }
+            }
+            t->sub_wp_viewport = wp_viewporter_get_viewport(process_wayland.wp_viewporter, t->sub_wl_surface);
+            t->sub_parent_hwnd = parent;
+            t->sub_x = t->sub_y = INT_MIN;
+            TRACE("created subsurface for hwnd=%p as child of toplevel=%p\n", hwnd, parent);
+        }
+
+        /* Anchor the subsurface at (0,0) of the parent's wl_surface. CEF's
+         * DComp output is the full visible browser content. */
+        if (t->sub_x != 0 || t->sub_y != 0)
+        {
+            wl_subsurface_set_position(t->sub_wl_subsurface, 0, 0);
+            t->sub_x = 0; t->sub_y = 0;
+            TRACE("subsurface position hwnd=%p set to (0,0)\n", hwnd);
+        }
+
+        wl_surface_attach(t->sub_wl_surface, t->shm_buffer->wl_buffer, 0, 0);
+        wl_surface_damage_buffer(t->sub_wl_surface, 0, 0, t->width, t->height);
+        /* CEF renders into the swap chain at device-pixel resolution (e.g.
+         * 1200x800 for the post-login launcher at 2.5x output scale). The
+         * parent toplevel's wayland_surface knows the correct fractional
+         * scale via wp_fractional_scale_v1 (e.g. 2.5x), so use that exact
+         * value rather than wine's process DPI (which may not match). Setting
+         * destination = buffer_size / scale gives an identity buffer→device
+         * mapping: surface_size * scale = buffer_size = device_pixels. */
+        if (t->sub_wp_viewport && psurface)
+        {
+            double scale = psurface->window.scale > 0 ? psurface->window.scale : 1.0;
+            int dw = (int)((double)t->width  / scale + 0.5);
+            int dh = (int)((double)t->height / scale + 0.5);
+            if (dw < 1) dw = 1;
+            if (dh < 1) dh = 1;
+            wp_viewport_set_source(t->sub_wp_viewport, 0, 0,
+                                   wl_fixed_from_int(t->width),
+                                   wl_fixed_from_int(t->height));
+            wp_viewport_set_destination(t->sub_wp_viewport, dw, dh);
+            TRACE("viewport src=%ux%u dst=%dx%d (parent scale=%.3f)\n",
+                  t->width, t->height, dw, dh, scale);
+        }
+        wl_surface_commit(t->sub_wl_surface);
+        wl_surface_commit(psurface->wl_surface);
+        wl_display_flush(process_wayland.wl_display);
+
+sub_done:
+        wayland_win_data_release(pdata);
+    }
+    TRACE("attached shm for hwnd=%p (subsurface path)\n", hwnd);
+}
