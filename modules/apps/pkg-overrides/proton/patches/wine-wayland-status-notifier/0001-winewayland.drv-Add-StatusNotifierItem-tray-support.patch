diff --git a/dlls/winewayland.drv/wayland_systray.c b/dlls/winewayland.drv/wayland_systray.c
new file mode 100644
index 00000000..994f63c7
--- /dev/null
+++ b/dlls/winewayland.drv/wayland_systray.c
@@ -0,0 +1,581 @@
+/*
+ * Wayland systray via freedesktop StatusNotifierItem (D-Bus)
+ *
+ * Copyright 2026 Alexander Schiffhauer
+ *
+ * Implements pSystrayDockInit / pSystrayDockInsert / pSystrayDockClear /
+ * pSystrayDockRemove using the org.kde.StatusNotifierItem spec.
+ * Works on KDE Plasma 6, GNOME + AppIndicator, and wlroots/Waybar.
+ * No XWayland or xembedsniproxy required.
+ *
+ * The `void *icon` parameter to pSystrayDockInsert is the `struct icon *`
+ * from programs/explorer/systray.c.  We read image, owner, window,
+ * callback_message, id, and tiptext from it.
+ */
+
+#if 0
+#pragma makedep unix
+#endif
+
+#include "config.h"
+
+/* Common includes required for Windows types regardless of D-Bus availability */
+#include "ntstatus.h"
+#define WIN32_NO_STATUS
+#include "waylanddrv.h"
+#include "wine/debug.h"
+
+WINE_DEFAULT_DEBUG_CHANNEL(systray);
+
+#ifdef SONAME_LIBDBUS_1
+
+#include <dbus/dbus.h>
+#include <pthread.h>
+#include <stdint.h>
+#include <stdlib.h>
+#include <string.h>
+#include <unistd.h>
+
+/* -----------------------------------------------------------------------
+ * explorer's struct icon layout - must stay in sync with
+ * programs/explorer/systray.c.  We only read the fields we need.
+ * ----------------------------------------------------------------------- */
+struct explorer_icon
+{
+    void       *list_fwd;
+    void       *list_bwd;
+    HICON       image;
+    HWND        owner;
+    HWND        window;
+    BOOL        layered;
+    HWND        tooltip;
+    UINT        state;
+    UINT        id;
+    UINT        callback_message;
+    int         display;
+    WCHAR       tiptext[128];
+};
+
+/* -----------------------------------------------------------------------
+ * Per-icon SNI service state
+ * ----------------------------------------------------------------------- */
+struct sni_item
+{
+    struct list     entry;
+    int             serial;
+    DBusConnection *conn;
+    HWND            owner_hwnd;
+    HWND            window_hwnd;
+    UINT            callback_message;
+    UINT            id;
+    int             icon_w, icon_h;
+    unsigned char  *icon_argb;
+    char            icon_name[128];
+    WCHAR           tiptext[128];
+};
+
+static struct list    sni_list   = LIST_INIT(sni_list);
+static int            sni_serial;
+static pthread_mutex_t sni_mutex = PTHREAD_MUTEX_INITIALIZER;
+static pthread_cond_t  sni_cond  = PTHREAD_COND_INITIALIZER;
+
+/* -----------------------------------------------------------------------
+ * Helpers
+ * ----------------------------------------------------------------------- */
+static void utf8_from_wchar(const WCHAR *src, char *dst, size_t dst_sz)
+{
+    ULONG bytes;
+    if (!RtlUnicodeToUTF8N(NULL, 0, &bytes, src,
+                            (lstrlenW(src) + 1) * sizeof(WCHAR)))
+        RtlUnicodeToUTF8N(dst, dst_sz, &bytes, src,
+                          (lstrlenW(src) + 1) * sizeof(WCHAR));
+    else
+        dst[0] = '\0';
+}
+
+static unsigned char *icon_to_argb32(HICON hicon, int *w_out, int *h_out)
+{
+    ICONINFO info = {0};
+    BITMAPINFOHEADER bih = { sizeof(bih) };
+    unsigned char *argb = NULL;
+    HDC hdc;
+    int w, h;
+
+    if (!NtUserGetIconInfo(hicon, &info, NULL, NULL, NULL, 0)) return NULL;
+
+    hdc = NtUserGetDC(NULL);
+    bih.biSize = sizeof(bih);
+    if (!NtGdiGetDIBitsInternal(hdc, info.hbmColor, 0, 0, NULL,
+                                (BITMAPINFO *)&bih, DIB_RGB_COLORS, 0, 0))
+        goto done;
+
+    w = bih.biWidth; h = abs(bih.biHeight);
+    if (w <= 0 || h <= 0) goto done;
+
+    bih.biBitCount    = 32;
+    bih.biCompression = BI_RGB;
+    bih.biHeight      = -h;
+    bih.biSizeImage   = w * h * 4;
+
+    if (!(argb = malloc(w * h * 4))) goto done;
+    if (!NtGdiGetDIBitsInternal(hdc, info.hbmColor, 0, h, argb,
+                                (BITMAPINFO *)&bih, DIB_RGB_COLORS,
+                                w * h * 4, 0))
+    {
+        free(argb); argb = NULL; goto done;
+    }
+
+    /* Convert BGRA (GDI) to ARGB big-endian (SNI (iiay)) */
+    for (int i = 0; i < w * h; i++)
+    {
+        unsigned char b = argb[i*4+0], g = argb[i*4+1],
+                      r = argb[i*4+2], a = argb[i*4+3];
+        argb[i*4+0] = a; argb[i*4+1] = r;
+        argb[i*4+2] = g; argb[i*4+3] = b;
+    }
+    *w_out = w; *h_out = h;
+
+done:
+    NtUserReleaseDC(NULL, hdc);
+    if (info.hbmColor) NtGdiDeleteObjectApp(info.hbmColor);
+    if (info.hbmMask)  NtGdiDeleteObjectApp(info.hbmMask);
+    return argb;
+}
+
+/* -----------------------------------------------------------------------
+ * D-Bus StatusNotifierItem XML
+ * ----------------------------------------------------------------------- */
+static const char sni_xml[] =
+    "<!DOCTYPE node PUBLIC \"-//freedesktop//DTD D-BUS Object Introspection"
+    " 1.0//EN\" \"http://www.freedesktop.org/standards/dbus/1.0/introspect.dtd\">\n"
+    "<node>\n"
+    " <interface name=\"org.kde.StatusNotifierItem\">\n"
+    "  <property name=\"Id\"         type=\"s\"        access=\"read\"/>\n"
+    "  <property name=\"Category\"   type=\"s\"        access=\"read\"/>\n"
+    "  <property name=\"Status\"     type=\"s\"        access=\"read\"/>\n"
+    "  <property name=\"Title\"      type=\"s\"        access=\"read\"/>\n"
+    "  <property name=\"IconName\"   type=\"s\"        access=\"read\"/>\n"
+    "  <property name=\"IconPixmap\" type=\"a(iiay)\"  access=\"read\"/>\n"
+    "  <property name=\"ToolTip\"    type=\"(sa(iiay)ss)\" access=\"read\"/>\n"
+    "  <method name=\"Activate\"><arg name=\"x\" type=\"i\"/><arg name=\"y\" type=\"i\"/></method>\n"
+    "  <method name=\"SecondaryActivate\"><arg name=\"x\" type=\"i\"/><arg name=\"y\" type=\"i\"/></method>\n"
+    "  <method name=\"ContextMenu\"><arg name=\"x\" type=\"i\"/><arg name=\"y\" type=\"i\"/></method>\n"
+    "  <method name=\"Scroll\"><arg name=\"delta\" type=\"i\"/><arg name=\"orientation\" type=\"s\"/></method>\n"
+    "  <signal name=\"NewIcon\"/>\n"
+    " </interface>\n"
+    " <interface name=\"org.freedesktop.DBus.Introspectable\">\n"
+    "  <method name=\"Introspect\"><arg name=\"xml\" type=\"s\" direction=\"out\"/></method>\n"
+    " </interface>\n"
+    " <interface name=\"org.freedesktop.DBus.Properties\">\n"
+    "  <method name=\"Get\">\n"
+    "   <arg name=\"interface\" type=\"s\" direction=\"in\"/>\n"
+    "   <arg name=\"name\"     type=\"s\" direction=\"in\"/>\n"
+    "   <arg name=\"value\"    type=\"v\" direction=\"out\"/>\n"
+    "  </method>\n"
+    "  <method name=\"GetAll\">\n"
+    "   <arg name=\"interface\" type=\"s\" direction=\"in\"/>\n"
+    "   <arg name=\"props\"    type=\"a{sv}\" direction=\"out\"/>\n"
+    "  </method>\n"
+    " </interface>\n"
+    "</node>\n";
+
+/* -----------------------------------------------------------------------
+ * Append icon pixmap array a(iiay)
+ * ----------------------------------------------------------------------- */
+static void append_pixmap(DBusMessageIter *iter, struct sni_item *item)
+{
+    DBusMessageIter arr, st, ba;
+    dbus_int32_t w = item->icon_w, h = item->icon_h;
+
+    dbus_message_iter_open_container(iter, DBUS_TYPE_ARRAY, "(iiay)", &arr);
+    if (item->icon_argb && w > 0 && h > 0)
+    {
+        dbus_message_iter_open_container(&arr, DBUS_TYPE_STRUCT, NULL, &st);
+        dbus_message_iter_append_basic(&st, DBUS_TYPE_INT32, &w);
+        dbus_message_iter_append_basic(&st, DBUS_TYPE_INT32, &h);
+        dbus_message_iter_open_container(&st, DBUS_TYPE_ARRAY, "y", &ba);
+        dbus_message_iter_append_fixed_array(&ba, DBUS_TYPE_BYTE,
+                                             &item->icon_argb,
+                                             (int)(w * h * 4));
+        dbus_message_iter_close_container(&st, &ba);
+        dbus_message_iter_close_container(&arr, &st);
+    }
+    dbus_message_iter_close_container(iter, &arr);
+}
+
+static BOOL append_sni_property(DBusMessageIter *iter, struct sni_item *item,
+                                const char *name)
+{
+    DBusMessageIter var;
+
+    if (!strcmp(name, "Id") || !strcmp(name, "Category") ||
+        !strcmp(name, "Status") || !strcmp(name, "Title") ||
+        !strcmp(name, "IconName"))
+    {
+        const char *str;
+        char id_buf[64], tip[256];
+
+        if (!strcmp(name, "Id"))
+        {
+            snprintf(id_buf, sizeof(id_buf), "wine-tray-%d", item->serial);
+            str = id_buf;
+        }
+        else if (!strcmp(name, "Category")) str = "ApplicationStatus";
+        else if (!strcmp(name, "Status"))   str = "Active";
+        else if (!strcmp(name, "IconName")) str = item->icon_name;
+        else
+        {
+            utf8_from_wchar(item->tiptext, tip, sizeof(tip));
+            str = tip;
+        }
+        dbus_message_iter_open_container(iter, DBUS_TYPE_VARIANT, "s", &var);
+        dbus_message_iter_append_basic(&var, DBUS_TYPE_STRING, &str);
+        dbus_message_iter_close_container(iter, &var);
+        return TRUE;
+    }
+    else if (!strcmp(name, "IconPixmap"))
+    {
+        dbus_message_iter_open_container(iter, DBUS_TYPE_VARIANT, "a(iiay)", &var);
+        append_pixmap(&var, item);
+        dbus_message_iter_close_container(iter, &var);
+        return TRUE;
+    }
+    else if (!strcmp(name, "ToolTip"))
+    {
+        DBusMessageIter st;
+        const char *empty = "";
+        char tip[256];
+        const char *tip_str = tip;
+
+        utf8_from_wchar(item->tiptext, tip, sizeof(tip));
+        dbus_message_iter_open_container(iter, DBUS_TYPE_VARIANT, "(sa(iiay)ss)", &var);
+        dbus_message_iter_open_container(&var, DBUS_TYPE_STRUCT, NULL, &st);
+        dbus_message_iter_append_basic(&st, DBUS_TYPE_STRING, &empty);
+        append_pixmap(&st, item);
+        dbus_message_iter_append_basic(&st, DBUS_TYPE_STRING, &tip_str);
+        dbus_message_iter_append_basic(&st, DBUS_TYPE_STRING, &empty);
+        dbus_message_iter_close_container(&var, &st);
+        dbus_message_iter_close_container(iter, &var);
+        return TRUE;
+    }
+
+    return FALSE;
+}
+
+static void append_sni_property_dict(DBusMessageIter *dict,
+                                     struct sni_item *item, const char *name)
+{
+    DBusMessageIter entry;
+
+    dbus_message_iter_open_container(dict, DBUS_TYPE_DICT_ENTRY, NULL, &entry);
+    dbus_message_iter_append_basic(&entry, DBUS_TYPE_STRING, &name);
+    append_sni_property(&entry, item, name);
+    dbus_message_iter_close_container(dict, &entry);
+}
+
+static LPARAM sni_mouse_lparam(HWND hwnd, dbus_int32_t x, dbus_int32_t y)
+{
+    POINT pt = {.x = x, .y = y};
+
+    if (!NtUserScreenToClient(hwnd, &pt))
+    {
+        pt.x = 0;
+        pt.y = 0;
+    }
+    return MAKELPARAM((short)pt.x, (short)pt.y);
+}
+
+static void post_tray_mouse_message(struct sni_item *item, UINT msg,
+                                    dbus_int32_t x, dbus_int32_t y)
+{
+    NtUserPostMessage(item->window_hwnd, msg, 0,
+                      sni_mouse_lparam(item->window_hwnd, x, y));
+}
+
+/* -----------------------------------------------------------------------
+ * D-Bus message handler
+ * ----------------------------------------------------------------------- */
+static DBusHandlerResult sni_handler(DBusConnection *conn, DBusMessage *msg,
+                                      void *user_data)
+{
+    struct sni_item *item = user_data;
+    const char *iface = dbus_message_get_interface(msg);
+    const char *member = dbus_message_get_member(msg);
+    DBusMessage *reply = NULL;
+
+    if (dbus_message_is_method_call(msg, DBUS_INTERFACE_INTROSPECTABLE, "Introspect"))
+    {
+        const char *xml = sni_xml;
+        reply = dbus_message_new_method_return(msg);
+        dbus_message_append_args(reply, DBUS_TYPE_STRING, &xml,
+                                 DBUS_TYPE_INVALID);
+        goto send;
+    }
+
+    if (dbus_message_is_method_call(msg, DBUS_INTERFACE_PROPERTIES, "Get"))
+    {
+        const char *name = NULL;
+        DBusMessageIter args;
+        dbus_message_get_args(msg, NULL,
+                              DBUS_TYPE_STRING, &iface,
+                              DBUS_TYPE_STRING, &name,
+                              DBUS_TYPE_INVALID);
+        reply = dbus_message_new_method_return(msg);
+        dbus_message_iter_init_append(reply, &args);
+        if (!name) goto send;
+        append_sni_property(&args, item, name);
+        goto send;
+    }
+
+    if (dbus_message_is_method_call(msg, DBUS_INTERFACE_PROPERTIES, "GetAll"))
+    {
+        static const char *props[] =
+        {
+            "Id", "Category", "Status", "Title", "IconName"
+        };
+        DBusMessageIter args, dict;
+        unsigned int i;
+
+        reply = dbus_message_new_method_return(msg);
+        dbus_message_iter_init_append(reply, &args);
+        dbus_message_iter_open_container(&args, DBUS_TYPE_ARRAY, "{sv}", &dict);
+        for (i = 0; i < sizeof(props) / sizeof(props[0]); i++)
+            append_sni_property_dict(&dict, item, props[i]);
+        dbus_message_iter_close_container(&args, &dict);
+        goto send;
+    }
+
+    if (iface && !strcmp(iface, "org.kde.StatusNotifierItem"))
+    {
+        UINT down_msg = 0, up_msg = 0;
+        dbus_int32_t x = 0, y = 0;
+        BOOL context_menu = FALSE;
+        if (!strcmp(member, "Activate"))
+        {
+            down_msg = WM_LBUTTONDOWN;
+            up_msg = WM_LBUTTONUP;
+        }
+        else if (!strcmp(member, "SecondaryActivate"))
+        {
+            down_msg = WM_MBUTTONDOWN;
+            up_msg = WM_MBUTTONUP;
+        }
+        else if (!strcmp(member, "ContextMenu"))
+        {
+            down_msg = WM_RBUTTONDOWN;
+            up_msg = WM_RBUTTONUP;
+            context_menu = TRUE;
+        }
+        else if (!strcmp(member, "Scroll"))
+        {
+            dbus_int32_t delta = 0;
+            dbus_message_get_args(msg, NULL, DBUS_TYPE_INT32, &delta,
+                                  DBUS_TYPE_INVALID);
+            NtUserPostMessage(item->owner_hwnd, item->callback_message,
+                              item->id,
+                              MAKELPARAM(0, delta > 0 ? WHEEL_DELTA : -WHEEL_DELTA));
+            reply = dbus_message_new_method_return(msg);
+            goto send;
+        }
+        if (up_msg)
+        {
+            dbus_message_get_args(msg, NULL,
+                                  DBUS_TYPE_INT32, &x, DBUS_TYPE_INT32, &y,
+                                  DBUS_TYPE_INVALID);
+            if (context_menu)
+                NtUserSetForegroundWindow(item->owner_hwnd);
+            post_tray_mouse_message(item, down_msg, x, y);
+            post_tray_mouse_message(item, up_msg, x, y);
+        }
+        reply = dbus_message_new_method_return(msg);
+        goto send;
+    }
+
+    return DBUS_HANDLER_RESULT_NOT_YET_HANDLED;
+
+send:
+    if (reply) { dbus_connection_send(conn, reply, NULL); dbus_message_unref(reply); }
+    return DBUS_HANDLER_RESULT_HANDLED;
+}
+
+static const DBusObjectPathVTable sni_vtable = { NULL, sni_handler };
+
+NTSTATUS wayland_systray_dispatch(void)
+{
+    struct sni_item *item;
+
+    for (;;)
+    {
+        pthread_mutex_lock(&sni_mutex);
+        while (list_empty(&sni_list))
+            pthread_cond_wait(&sni_cond, &sni_mutex);
+        LIST_FOR_EACH_ENTRY(item, &sni_list, struct sni_item, entry)
+            dbus_connection_read_write_dispatch(item->conn, 100);
+        pthread_mutex_unlock(&sni_mutex);
+    }
+    return STATUS_SUCCESS;
+}
+
+/* -----------------------------------------------------------------------
+ * Public driver hooks
+ * ----------------------------------------------------------------------- */
+
+void WAYLAND_SystrayDockInit(HWND hwnd)
+{
+    TRACE("hwnd=%p\n", hwnd);
+}
+
+BOOL WAYLAND_SystrayDockInsert(HWND hwnd, UINT cx, UINT cy, void *icon_data)
+{
+    struct explorer_icon *icon = icon_data;
+    struct sni_item *item;
+    DBusError err;
+    char service[128], obj_path[] = "/StatusNotifierItem", rule[256];
+    int ret;
+
+    if (!icon) return FALSE;
+
+    dbus_error_init(&err);
+    item = calloc(1, sizeof(*item));
+    if (!item) return FALSE;
+
+    pthread_mutex_lock(&sni_mutex);
+    item->serial = ++sni_serial;
+    pthread_mutex_unlock(&sni_mutex);
+
+    item->owner_hwnd       = icon->owner;
+    item->window_hwnd      = icon->window;
+    item->callback_message = icon->callback_message;
+    item->id               = icon->id;
+    memcpy(item->tiptext, icon->tiptext, sizeof(item->tiptext));
+
+    if (icon->image)
+        item->icon_argb = icon_to_argb32(icon->image, &item->icon_w, &item->icon_h);
+
+    {
+        const char *icon_name = getenv("WINE_SNI_ICON_NAME");
+        if (icon_name && *icon_name)
+            snprintf(item->icon_name, sizeof(item->icon_name), "%s", icon_name);
+    }
+
+    snprintf(service, sizeof(service),
+             "org.kde.StatusNotifierItem-%d-%d", (int)getpid(), item->serial);
+
+    item->conn = dbus_bus_get_private(DBUS_BUS_SESSION, &err);
+    if (!item->conn || dbus_error_is_set(&err))
+    {
+        WARN("D-Bus connect failed: %s\n", dbus_error_is_set(&err) ? err.message : "");
+        dbus_error_free(&err);
+        free(item->icon_argb); free(item);
+        return FALSE;
+    }
+
+    ret = dbus_bus_request_name(item->conn, service,
+                                DBUS_NAME_FLAG_REPLACE_EXISTING, &err);
+    if (ret != DBUS_REQUEST_NAME_REPLY_PRIMARY_OWNER || dbus_error_is_set(&err))
+    {
+        WARN("Could not claim %s: %s\n", service,
+             dbus_error_is_set(&err) ? err.message : "");
+        dbus_error_free(&err);
+        dbus_connection_close(item->conn);
+        dbus_connection_unref(item->conn);
+        free(item->icon_argb); free(item);
+        return FALSE;
+    }
+
+    if (!dbus_connection_register_object_path(item->conn, obj_path,
+                                              &sni_vtable, item))
+    {
+        ERR("register_object_path failed\n");
+        dbus_connection_close(item->conn);
+        dbus_connection_unref(item->conn);
+        free(item->icon_argb); free(item);
+        return FALSE;
+    }
+
+    {
+        DBusMessage *reg = dbus_message_new_method_call(
+            "org.kde.StatusNotifierWatcher", "/StatusNotifierWatcher",
+            "org.kde.StatusNotifierWatcher", "RegisterStatusNotifierItem");
+        if (reg)
+        {
+            const char *svc = service;
+            dbus_message_append_args(reg, DBUS_TYPE_STRING, &svc,
+                                     DBUS_TYPE_INVALID);
+            dbus_connection_send(item->conn, reg, NULL);
+            dbus_connection_flush(item->conn);
+            dbus_message_unref(reg);
+        }
+    }
+
+    snprintf(rule, sizeof(rule),
+             "type='signal',sender='org.kde.StatusNotifierWatcher'");
+    dbus_bus_add_match(item->conn, rule, NULL);
+
+    pthread_mutex_lock(&sni_mutex);
+    list_add_tail(&sni_list, &item->entry);
+    pthread_cond_signal(&sni_cond);
+    pthread_mutex_unlock(&sni_mutex);
+
+    TRACE("registered SNI %s hwnd=%p owner=%p id=%u\n",
+          service, hwnd, icon->owner, icon->id);
+    return TRUE;
+}
+
+void WAYLAND_SystrayDockClear(HWND hwnd)
+{
+    struct sni_item *item;
+    pthread_mutex_lock(&sni_mutex);
+    LIST_FOR_EACH_ENTRY(item, &sni_list, struct sni_item, entry)
+    {
+        if (item->window_hwnd == hwnd)
+        {
+            DBusMessage *sig = dbus_message_new_signal(
+                "/StatusNotifierItem", "org.kde.StatusNotifierItem", "NewIcon");
+            if (sig)
+            {
+                dbus_connection_send(item->conn, sig, NULL);
+                dbus_connection_flush(item->conn);
+                dbus_message_unref(sig);
+            }
+            break;
+        }
+    }
+    pthread_mutex_unlock(&sni_mutex);
+}
+
+BOOL WAYLAND_SystrayDockRemove(HWND hwnd)
+{
+    struct sni_item *item, *found = NULL;
+    pthread_mutex_lock(&sni_mutex);
+    LIST_FOR_EACH_ENTRY(item, &sni_list, struct sni_item, entry)
+        if (item->window_hwnd == hwnd) { found = item; break; }
+    if (found) list_remove(&found->entry);
+    pthread_cond_signal(&sni_cond);
+    pthread_mutex_unlock(&sni_mutex);
+    if (!found) return FALSE;
+
+    dbus_connection_close(found->conn);
+    dbus_connection_unref(found->conn);
+    free(found->icon_argb);
+    free(found);
+    return TRUE;
+}
+
+#else /* !SONAME_LIBDBUS_1 */
+
+void WAYLAND_SystrayDockInit(HWND hwnd) {}
+
+BOOL WAYLAND_SystrayDockInsert(HWND hwnd, UINT cx, UINT cy, void *icon)
+{
+    FIXME("D-Bus not available; systray icon not registered\n");
+    return FALSE;
+}
+
+void WAYLAND_SystrayDockClear(HWND hwnd) {}
+
+BOOL WAYLAND_SystrayDockRemove(HWND hwnd) { return FALSE; }
+
+NTSTATUS wayland_systray_dispatch(void) { return STATUS_NOT_IMPLEMENTED; }
+
+#endif /* SONAME_LIBDBUS_1 */
